    @Transactional
    public List<JournalRequest> createBatchRequest(BatchPostingDto dto, String creatorId, Integer creatorRole)  {
        String batchId = sequenceService.getNextBatchId();
        String journalPrefix = sequenceService.getNextJournalIdPrefix();

        // --- STRICT VID DUPLICATION CHECK ---
        if (dto.getVid() == null || dto.getVid().trim().isEmpty()) {
            throw new CustomExceptions.InvalidDataException("VID is missing from the payload. Cannot save batch.");
        }

        // Checks if the VID is already used by an active/pending batch, ignoring rejected ones
        Integer vidExists = jdbcTemplate.queryForObject(
                "SELECT COUNT(*) FROM VOUCHER_POSTING WHERE VID_FK = ? AND BATCH_STATUS NOT IN ('R', 'REJECTED', 'ERROR')",
                Integer.class, dto.getVid()
        );

        if (vidExists != null && vidExists > 0) {
            throw new CustomExceptions.InvalidDataException("Voucher ID (" + dto.getVid() + ") is currently in use by an active batch. Please select a fresh VID.");
        }

        List<JournalRequest> entities = new ArrayList<>();
        Map<String, BigDecimal> balancingMap = new java.util.HashMap<>();
        int rowIndex = 1;

        for (BatchPostingDto.JournalRequestRow row : dto.getRows()) {
            JournalRequest entity = new JournalRequest();
            entity.setRequestStatus(RequestStatus.PENDING);
            entity.setRequestDate(LocalDateTime.now());
            entity.setCreatorId(creatorId);
            entity.setBatchId(batchId);

            String journalId = journalPrefix + "-" + rowIndex;
            entity.setJournalId(journalId);
            entity.setBranchCode(row.getBranch());
            entity.setCurrency(row.getCurrency());

            String cgl = row.getCgl() != null ? row.getCgl().trim() : "";
            entity.setCgl(cgl);

            BigDecimal amount = row.getAmount();

            if (amount == null || amount.compareTo(BigDecimal.ZERO) == 0) {
                throw new CustomExceptions.InvalidDataException("Transaction amount cannot be zero.");
            }

            entity.setAmount(amount);
            entity.setNarration(row.getRemarks());
            entity.setProductCode(row.getProductType());

            // --- STRICT BACKEND BALANCING RULE ---
            // 1. Create Composite Key (e.g., "10301-INR-MEMO")
            String cglType = cgl.startsWith("5") ? "MEMO" : "NORMAL";
            String compositeKey = row.getBranch() + " - " + row.getCurrency() + " - " + cglType;

            // 2. Add to Group Balance (Debits are positive, Credits are negative)
            // If the UI sends "Credit" as negative, it naturally subtracts.
            // If the UI sends it as positive but flags it as "Credit", make sure to handle that negation here.
                balancingMap.put(compositeKey, balancingMap.getOrDefault(compositeKey, BigDecimal.ZERO).add(amount));

            entities.add(entity);
            rowIndex++;
        }

        // --- ENFORCE BALANCE ---
        // If Debits and Credits match perfectly, the sum for every group will be exactly 0.00
        for (Map.Entry<String, BigDecimal> entry : balancingMap.entrySet()) {
            if (entry.getValue().compareTo(BigDecimal.ZERO) != 0) {
                throw new CustomExceptions.InvalidDataException(
                        "Balancing rule failed for [" + entry.getKey() + "]. Total Debits and Credits must exactly match."
                );
            }
        }

        List<JournalRequest> savedEntities = journalRequestRepository.saveAll(entities);

        // ==========================================
        // 2. DYNAMIC WORKFLOW INITIALIZATION (FOREIGN KEY BASED)
        // ==========================================
        String workflowCode;
        try {
            workflowCode = jdbcTemplate.queryForObject(
                    "SELECT WORKFLOW_CODE FROM WORKFLOW_TRANSITIONS WHERE ALLOWED_ROLE_ID = ? AND WORKFLOW_ORDER = 1 FETCH FIRST 1 ROWS ONLY",
                    String.class, creatorRole
            );
        } catch (EmptyResultDataAccessException e) {
            throw new CustomExceptions.InvalidDataException("Configuration Error: No workflow mapped for Role ID " + creatorRole);
        }

        // --- FETCH BOTH WORKFLOW_ID AND ALLOWED_ROLE_ID FOR STEP 2 ---
        Map<String, Object> step2Info;
        try {
            step2Info = jdbcTemplate.queryForMap(
                    "SELECT WORKFLOW_ID, ALLOWED_ROLE_ID FROM WORKFLOW_TRANSITIONS WHERE WORKFLOW_CODE = ? AND WORKFLOW_ORDER = 2",
                    workflowCode
            );
        } catch (EmptyResultDataAccessException e) {
            throw new CustomExceptions.InvalidDataException("Configuration Error: Missing Step 2 for " + workflowCode);
        }

        Long firstApproverWorkflowId = ((Number) step2Info.get("WORKFLOW_ID")).longValue();
        String nextApproverRoleId = String.valueOf(step2Info.get("ALLOWED_ROLE_ID"));

        VoucherPosting posting = new VoucherPosting();
        posting.setBatchId(batchId);
        posting.setVidFk(dto.getVid());
        posting.setCreatedBy(creatorId);
        posting.setPendingAt(firstApproverWorkflowId);
        posting.setBatchStatus("S"); // 'P' = Pending
        posting.setWorkflowCode(workflowCode);
        posting.setCommonBatchRemarks(dto.getCommonBatchRemarks());
        posting.setCreatorRole(creatorRole);

        if (dto.getRows() != null) {
            posting.setRecordsCount((long) dto.getRows().size());
        }

        // Handle Maker Scheduling
        if (dto.getScheduledTime() != null) {
            workflowEngine.validateScheduledTime(dto.getScheduledTime());
            posting.setIS_EXECUTION_SCHEDULED("YES");
            posting.setScheduledTime(dto.getScheduledTime());
            posting.setIsScheduleOverride("NO");
        } else {
            posting.setIS_EXECUTION_SCHEDULED("NO");
            posting.setIsScheduleOverride("NO");
        }

        voucherPostingRepository.save(posting);

        logAudit(creatorId, "BATCH_MANUAL", "ADD", "Manual Batch " + batchId + " Created under " + workflowCode);

        // ==========================================
        // SMART NOTIFICATION ROUTING
        // ==========================================
        // 1. Notify the Checkers (Strictly to TARGET_ROLE)
        notificationWriterService.createNextStepApprovalNotification(batchId, nextApproverRoleId);

        // ---> TRIGGER 1: LOCK THE VID AS USED <---
        if (dto.getVid() != null && !dto.getVid().isEmpty()) {
            workflowEngine.updateVidStatus(dto.getVid(), VoucherStatus.USED);
        }

        workflowEngine.logWorkflowAction(batchId, dto.getVid(), "Submitted", creatorId, dto.getCommonBatchRemarks(), dto.getScheduledTime());

        return savedEntities;
    }
    // ==================================================================================
    // 4. BATCH / RECORD DELETION
    // ==================================================================================
    public void deleteBatchRequest(String batchId, String userId) {
        // 1. Fetch the batch
        VoucherPosting batch = voucherPostingRepository.findById(batchId)
                .orElseThrow(() -> new CustomExceptions.InvalidDataException("Batch not found."));

        // 2. SECURITY CHECK: Only the creator can delete it
        if (!batch.getCreatedBy().equalsIgnoreCase(userId)) {
            log.warn("SECURITY_VIOLATION | User {} attempted to delete batch {} owned by {}", userId, batchId, batch.getCreatedBy());
            throw new IllegalStateException("You do not have permission to delete this batch.");
        }

        // 3. STATE CHECK: Can only delete if it is still PENDING ('P')
        if (!"P".equalsIgnoreCase(batch.getBatchStatus())) {
            throw new IllegalStateException("Only Pending batches can be deleted. Current status: " + batch.getBatchStatus());
        }

        // 4. STRICT WORKFLOW ORDER CHECK: Ensure it is exactly at Order 2
        String orderSql = """
            SELECT wt.WORKFLOW_ORDER 
            FROM VOUCHER_POSTING vp 
            JOIN WORKFLOW_TRANSITIONS wt ON vp.PENDING_AT = wt.WORKFLOW_ID 
            WHERE vp.BATCH_ID = ?
        """;
        Integer currentOrder;
        try {
            currentOrder = jdbcTemplate.queryForObject(orderSql, Integer.class, batchId);
        } catch (EmptyResultDataAccessException e) {
            currentOrder = -1; // Failsafe
        }

        if (currentOrder == null || currentOrder != 2) {
            throw new IllegalStateException("Batch cannot be deleted as it has already been processed or moved from the initial stage.");
        }



        // 6. Hand off to the background thread to do the heavy database deletion
        asyncWorker.executeAsyncBatchCancellation(batchId, userId);
    }


    @Transactional
    public void cancelMyRequest(Long requestId, String userId) {
        JournalRequest request = journalRequestRepository.findById(requestId)
                .orElseThrow(() -> new RuntimeException("Request not found: " + requestId)); // Replace RuntimeException with your custom ResourceNotFoundException if you have one

        if (!request.getCreatorId().equalsIgnoreCase(userId)) {
            log.warn("UNAUTHORIZED_DELETE | User: {} | RequestOwner: {} | ReqID: {}", userId, request.getCreatorId(), requestId);
            throw new IllegalStateException("You can only cancel your own requests.");
        }

        if (request.getRequestStatus() != RequestStatus.PENDING) {
            throw new IllegalStateException("Only PENDING requests can be cancelled. Current: " + request.getRequestStatus());
        }

        journalRequestRepository.delete(request);
        log.info("REQUEST_CANCELLED | User: {} | ReqID: {}", userId, requestId);
    }

    @Transactional
    public void updateBatchSchedule(String batchId, String scheduledTime) {
        Integer exists = jdbcTemplate.queryForObject("SELECT COUNT(*) FROM VOUCHER_POSTING WHERE BATCH_ID = ?", Integer.class, batchId);
        if (exists == null || exists == 0) {
            throw new CustomExceptions.InvalidDataException("The batch is still being initialized. Please wait a few seconds.");
        }

        if (scheduledTime != null && !scheduledTime.isEmpty()) {
            LocalDateTime parsedTime = LocalDateTime.parse(scheduledTime, java.time.format.DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));
            workflowEngine.validateScheduledTime(parsedTime);

            jdbcTemplate.update("UPDATE VOUCHER_POSTING SET SCHEDULED_TIME = TO_TIMESTAMP(?, 'YYYY-MM-DD HH24:MI:SS'), IS_SCHEDULE_OVERRIDE = 'NO', IS_EXECUTION_SCHEDULED = 'YES' WHERE BATCH_ID = ?", scheduledTime, batchId);
            jdbcTemplate.update("UPDATE VOUCHER_WORKFLOW SET SCHEDULED_TIME = TO_TIMESTAMP(?, 'YYYY-MM-DD HH24:MI:SS') WHERE BATCH_ID_FK = ? AND LAST_ACTION = 'Submitted'", scheduledTime, batchId);
        }

        // SMART DOUBLE-LOCK LOGIC:
        // Check if the AsyncWorker is still writing data. (If actual rows match requested rows, it's done!)
        String checkDataLoadedSql = """
            SELECT CASE WHEN p.RECORDS_COUNT = (SELECT COUNT(*) FROM VOUCHER_POSTING_DATA d WHERE d.BATCH_ID = p.BATCH_ID) 
            THEN 1 ELSE 0 END FROM VOUCHER_POSTING p WHERE p.BATCH_ID = ?
        """;

        Integer isDataLoaded = jdbcTemplate.queryForObject(checkDataLoadedSql, Integer.class, batchId);

        if (isDataLoaded != null && isDataLoaded == 1) {
            // Data is fully loaded. Safe to show to checkers!
            jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'P' WHERE BATCH_ID = ?", batchId);
        } else {
            // Data is still inserting. Leave it as 'S'. The Async Worker will flip it to 'P' when it finishes.
            log.info("Schedule saved for Batch {}, but data is still loading. Status remains 'S'.", batchId);
        }
    }

    private void logAudit(String user, String action, String type, String val) {
        try {
            JournalLog l = new JournalLog();
            l.setUserId(user);
            l.setActionType(action);
            l.setChangeType(type);
            l.setNewValue(val.length() > 3900 ? val.substring(0, 3900) : val);
            l.setActionTime(LocalDateTime.now());
            voucherLogRepository.save(l);
        } catch (DataAccessException e) {
            log.error("AUDIT_LOG_FAIL | User: {} | Status: Persistence error", user);
        }
    }
}


