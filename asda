    public Map<String, Object> getBatchSummaryDetails(String batchId) {
        String sql = """
            SELECT 
                vp.VID_FK AS VID,
                vp.CREATED_BY AS BATCH_CREATOR_ID,
                COALESCE(bu.FIRST_NAME || ' ' || bu.LAST_NAME, vp.CREATED_BY) AS BATCH_CREATED_BY_NAME,
                vp.CREATED_AT AS BATCH_CREATED_AT,
                vp.CREATOR_ROLE AS CREATORS_ROLE,
                vp.SCHEDULED_TIME,
                vp.EXECUTED_AT,
                vc.CATEGORY_NAME,
                
                -- NEW: Fetch and comma-separate all mapped Issue Categories
                (
                    SELECT LISTAGG(ic.ISSUE_CATEGORY_NAME, ', ') WITHIN GROUP (ORDER BY ic.ISSUE_CATEGORY_NAME)
                    FROM REQUEST_VOUCHER_ISSUE_CATEGORY rvic
                    JOIN ISSUE_CATEGORY ic ON rvic.ISSUE_CATEGORY_ID = ic.ID
                    WHERE rvic.REQUEST_VOUCHER_ID = rv.ID
                ) AS ISSUE_CATEGORIES,
                
                rv.CREATED_BY AS VID_CREATOR_ID,
                COALESCE(vu.FIRST_NAME || ' ' || vu.LAST_NAME, rv.CREATED_BY) AS VID_CREATED_BY_NAME,
                rv.CREATED_AT AS VID_CREATED_AT,
                rv.DESCRIPTION
            FROM VOUCHER_POSTING vp
            LEFT JOIN REQUEST_VOUCHER rv ON vp.VID_FK = rv.VID
            LEFT JOIN VOUCHER_CATEGORY vc ON rv.CATEGORY_ID = vc.ID
            LEFT JOIN USERS bu ON vp.CREATED_BY = bu.USER_ID
            LEFT JOIN USERS vu ON rv.CREATED_BY = vu.USER_ID
            WHERE vp.BATCH_ID = ?
        """;

        try {
            return jdbcTemplate.queryForMap(sql, batchId);
        } catch (EmptyResultDataAccessException e) {
            return new HashMap<>();
        }
    }


