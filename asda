    @Transactional
    public String createBatchFromCacheAsync(String requestId, String commonRemarks, String creatorId, Integer creatorRole, String vid) {
        String lockKey = "LOCK_REQ_" + requestId;
        Boolean acquired;

        try {
            acquired = redisTemplate.opsForValue().setIfAbsent(lockKey, new byte[0], 60, TimeUnit.MINUTES);
        } catch (DataAccessException e) {
            log.error("REDIS_LOCK_FAIL | ReqID: {} | Status: Connection to lock service failed", requestId);
            throw new CustomExceptions.DatabaseOperationException("Distributed lock service unavailable", e);
        }

        if (Boolean.FALSE.equals(acquired)) {
            log.warn("CONCURRENCY_LOCKED | ReqID: {} | Status: Processing already in progress", requestId);
            throw new CustomExceptions.ConcurrencyLockException("Batch creation is already in progress for this Request ID.");
        }

        try {
            // ? FIX 1: Validate VID existence to prevent "null" crashes
            if (vid == null || vid.trim().isEmpty()) {
                throw new CustomExceptions.InvalidDataException("VID is missing from the payload. Cannot save batch.");
            }

            // ? FIX 2: Check if VID is already used! This completely prevents the HTTP 409 Constraint Violation!
            Integer vidExists = jdbcTemplate.queryForObject(
                    "SELECT COUNT(*) FROM VOUCHER_POSTING WHERE VID_FK = ? AND BATCH_STATUS NOT IN ('R', 'REJECTED')",
                    Integer.class, vid
            );
            if (vidExists != null && vidExists > 0) {
                throw new CustomExceptions.InvalidDataException("Voucher ID (" + vid + ") has already been used in another batch. Please select a fresh VID.");
            }

            // 1. GENERATE IDs
            String batchId = sequenceService.getNextBatchId();
            String journalPrefix = sequenceService.getNextJournalIdPrefix();

            // 2. FETCH ROW COUNT
            byte[] metaBytes = redisTemplate.opsForValue().get("DATA_META_" + requestId);
            long totalRows = 0;
            if (metaBytes != null) {
                try {
                    Map<String, Object> meta = objectMapper.readValue(metaBytes, new TypeReference<>() {});
                    totalRows = ((Number) meta.get("totalRows")).longValue();
                } catch (Exception ignored) {}
            }

            // 3. WORKFLOW ROUTING
            String workflowCode;
            try {
                workflowCode = jdbcTemplate.queryForObject(
                        "SELECT WORKFLOW_CODE FROM WORKFLOW_TRANSITIONS WHERE ALLOWED_ROLE_ID = ? AND WORKFLOW_ORDER = 1 FETCH FIRST 1 ROWS ONLY",
                        String.class, creatorRole
                );
            } catch (EmptyResultDataAccessException e) {
                throw new CustomExceptions.InvalidDataException("Configuration Error: No workflow mapped for Role ID " + creatorRole);
            }

            Long firstApproverWorkflowId;
            try {
                firstApproverWorkflowId = jdbcTemplate.queryForObject(
                        "SELECT WORKFLOW_ID FROM WORKFLOW_TRANSITIONS WHERE WORKFLOW_CODE = ? AND WORKFLOW_ORDER = 2",
                        Long.class, workflowCode
                );
            } catch (EmptyResultDataAccessException e) {
                throw new CustomExceptions.InvalidDataException("Configuration Error: Missing Step 2 for " + workflowCode);
            }

            // 4. SYNCHRONOUS MASTER RECORD CREATION
            VoucherPosting posting = new VoucherPosting();
            posting.setBatchId(batchId);
            posting.setVidFk(vid);
            posting.setCommonBatchRemarks(commonRemarks);
            posting.setCreatorRole(creatorRole);
            posting.setCreatedBy(creatorId);
            posting.setWorkflowCode(workflowCode);
            posting.setPendingAt(firstApproverWorkflowId);
            posting.setBatchStatus("S");

            posting.setIS_EXECUTION_SCHEDULED("NO");
            posting.setScheduledTime(null);
            posting.setIsScheduleOverride("NO");
            posting.setRecordsCount(totalRows);

            voucherPostingRepository.save(posting);

            // 5. UPDATE DEPENDENCIES
            workflowEngine.updateVidStatus(vid, VoucherStatus.USED);
            workflowEngine.logWorkflowAction(batchId, vid, "Submitted", creatorId, commonRemarks, null);

            progressService.sendProgress(batchId, creatorId, 0, "PROCESSING", "Initializing Batch Creation...");

            // 6. ASYNC HANDOFF (Pass to background thread)
            asyncWorker.executeAsyncBatchCreation(batchId, journalPrefix, requestId, commonRemarks, creatorId, creatorRole, vid);

            return batchId;
        }
        catch (org.springframework.dao.DataIntegrityViolationException e) {
            redisTemplate.delete(lockKey);
            log.error("DB_CONSTRAINT_FAIL | ReqID: {} | Error: {}", requestId, e.getRootCause() != null ? e.getRootCause().getMessage() : e.getMessage());
            throw new CustomExceptions.InvalidDataException("Database constraint failed. Ensure the VID is not duplicated or missing.");
        }
        catch (DataAccessException e) {
            redisTemplate.delete(lockKey);
            log.error("SEQUENCE_GEN_FAIL | ReqID: {} | Status: Failed to generate sequence", requestId);
            throw new CustomExceptions.DatabaseOperationException("Failed to generate Batch ID sequence", e);
        }
    }

