    @Transactional
    public void processBulkRequestsAsync(BulkProcessVoucherPostingDto dto, String executorId, Integer executorRole) {
        // Robust batch update lock statement safely scoping both standard and timer pending steps
        String lockSql = "UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'A' WHERE BATCH_ID = ? AND BATCH_STATUS IN ('P', 'PENDING')";
        int updated = jdbcTemplate.update(lockSql, dto.getBatchId());

        if (updated == 0) {
            log.warn("APPROVAL_LOCK_FAIL | Batch: {} | Status: Already processing or invalid status", dto.getBatchId());
            throw new IllegalStateException("Batch is already being processed or is not in a valid state for execution.");
        }

        progressService.sendProgress(dto.getBatchId(), executorId, 0, "PROCESSING", "Approval Queued...");
        asyncWorker.executeAsyncBatchProcessing(dto, executorId);
    }


