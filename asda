  const isRowRemarksValid = (val) => val.trim().length >= 2 && val.trim().length <= 30;
  const filterAndWarn = (val) => {
    let filtered = val;
    let hasError = false;
    let msg = "Only alphanumeric, spaces, and / & ( ) , . - are allowed.";

    // 1. Corrected Regex: Allows Alphanumeric, Spaces, and / & ( ) , . -
    const invalidCharRegex = /[^a-zA-Z0-9 \/&(),.\-]/g;

    if (invalidCharRegex.test(filtered)) {
      hasError = true;
      filtered = filtered.replace(invalidCharRegex, "");
