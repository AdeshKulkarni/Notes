package com.fincore.VoucherService.Dto;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.Pattern;
import jakarta.validation.constraints.AssertTrue;
import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@Data
@NoArgsConstructor
@AllArgsConstructor
public class VoucherRowDto {

    @NotBlank(message = "Branch is mandatory")
    private String branch;

    @NotBlank(message = "Currency is mandatory")
    private String currency;

    @NotBlank(message = "CGL is mandatory")
    private String cgl;

    // Allows optional '-', up to 16 digits, and optional decimal up to 4 places
    @NotBlank(message = "Amount is mandatory")
    @Pattern(regexp = "^-?\\d{1,16}(\\.\\d{1,4})?$", message = "Amount must be a valid number with up to 16 digits and a maximum of 4 decimal places")
    private String amount;

    // Optional field, so we just restrict it to 0-8 digits
    @Pattern(regexp = "^\\d{0,8}$", message = "Product Code must be a maximum of 8 digits")
    private String productCode;

    @NotBlank(message = "Remarks are mandatory")
    @Pattern(regexp = "^[a-zA-Z0-9]{2,30}$", message = "Remarks must be between 2 and 30 alphanumeric characters")
    private String remarks;

    @NotBlank(message = "AR Flag is mandatory")
    private String arFlag;

    // --- CROSS-FIELD VALIDATION (The Currency/Decimal Rule) ---
    // Spring Boot will automatically run any method annotated with @AssertTrue during validation
    @AssertTrue(message = "INR currency allows a maximum of 2 decimal places. Other currencies allow up to 4.")
    public boolean isAmountDecimalValid() {
        if (amount == null || currency == null) return true; // Skip if null, let @NotBlank handle the error

        String[] parts = amount.replace("-", "").split("\\.");
        int fractionLength = parts.length > 1 ? parts[1].length() : 0;

        if ("INR".equalsIgnoreCase(currency)) {
            return fractionLength <= 2;
        } else {
            return fractionLength <= 4;
        }
    }


}

