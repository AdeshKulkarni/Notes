            createStyledCell(stage2Row, 1, "Cross-references record fields against active system reference masters. Validates that the requested Branch Code, Currency Identifier, and CGL exist and are active in the database.", bodyStyle);

            Row stage3Row = guidelineSheet.createRow(3);
            stage3Row.setHeightInPoints(40);
            createStyledCell(stage3Row, 0, "Stage 3: Balance Verification", bodyStyle);
            createStyledCell(stage3Row, 1, "Aggregates values row-by-row ensuring total Debits equal to total Credits.", bodyStyle);

            // ==========================================
            // 4. WRITE TO STREAM AT THE END
            // ==========================================
            // This is moved to the absolute bottom so both sheets are included in the file
            ByteArrayOutputStream bos = new ByteArrayOutputStream();
            workbook.write(bos);

            return bos.toByteArray();
        }
    }

    private void applyHighlighting(XSSFRichTextString richText, String fullText, String targetWord, Font font) {
        int index = 0;
        while ((index = fullText.indexOf(targetWord, index)) != -1) {
            richText.applyFont(index, index + targetWord.length(), font);
            index += targetWord.length();
        }
    }

    private void createStyledCell(Row row, int column, String value, CellStyle style) {
        Cell cell = row.createCell(column);
        cell.setCellValue(value);
        cell.setCellStyle(style);
    }
}
package com.fincore.VoucherService.Service.validation;


import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.VoucherService.Dto.BulkUploadStateDto;
import com.fincore.VoucherService.Dto.ExcelRowData;
import com.fincore.VoucherService.Exception.CustomExceptions;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.dao.DataAccessException;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.stereotype.Service;

import java.io.ByteArrayInputStream;
import java.io.ByteArrayOutputStream;
import java.io.IOException;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.TimeUnit;
import java.util.function.Consumer;
import java.util.zip.GZIPInputStream;
import java.util.zip.GZIPOutputStream;

@Service
@Slf4j
public class ValidationStateManager {

    private final ObjectMapper objectMapper;

    @Autowired
    @Qualifier("byteArrayRedisTemplate")
    private RedisTemplate<String, byte[]> redisTemplate;

    public ValidationStateManager(ObjectMapper objectMapper) {
        this.objectMapper = objectMapper;
    }

    // ==================================================================================
    // 1. REDIS STATE MANAGEMENT
    // ==================================================================================
    public void saveStatusToRedis(String reqId, BulkUploadStateDto state) {
        try {
            byte[] json = objectMapper.writeValueAsBytes(state);
            redisTemplate.opsForValue().set("BULK_STATUS_" + reqId, json, 2, TimeUnit.HOURS);
        } catch (JsonProcessingException e) {
            log.error("SERIALIZATION_FAIL | ReqID: {} | Status: Object mapping error", reqId);
        } catch (DataAccessException e) {
            log.error("REDIS_WRITE_FAIL | ReqID: {} | Status: Connection/Persistence failure", reqId);
        }
    }

    public BulkUploadStateDto getStatusFromRedis(String reqId) {
        try {
            byte[] json = redisTemplate.opsForValue().get("BULK_STATUS_" + reqId);
            if (json == null) return null;
            return objectMapper.readValue(json, BulkUploadStateDto.class);
        } catch (IOException | DataAccessException e) {
            log.error("REDIS_READ_FAIL | ReqID: {} | Type: {}", reqId, e.getClass().getSimpleName());
            return null;
        }
    }
    public synchronized void updateState(String requestId, Consumer<BulkUploadStateDto> updater) {
        BulkUploadStateDto state = getStatusFromRedis(requestId);
        if (state == null) {
            state = new BulkUploadStateDto();
            state.setRequestId(requestId);
        }
        updater.accept(state);
        saveStatusToRedis(requestId, state);
    }


    public List<ExcelRowData> getValidRowsFromCache(String requestId) {
        byte[] metaBytes = redisTemplate.opsForValue().get("DATA_META_" + requestId);
        if (metaBytes == null) {
            throw new CustomExceptions.CacheExpiredException("Validation data expired (TTL 1 Hour). Please re-upload.");
        }

        try {
            Map<String, Object> meta = objectMapper.readValue(metaBytes, new TypeReference<>() {});
            int totalChunks = (int) meta.get("totalChunks");
            int totalRows = (int) meta.get("totalRows");
            List<ExcelRowData> allRows = new ArrayList<>(totalRows);

            for (int i = 0; i < totalChunks; i++) {
                byte[] compressedChunk = redisTemplate.opsForValue().get("DATA_CHUNK_" + requestId + "_" + i);
                if (compressedChunk == null) {
                    throw new CustomExceptions.CacheExpiredException("Missing data chunk " + i + ". Please re-upload.");
                }
                try (GZIPInputStream gis = new GZIPInputStream(new ByteArrayInputStream(compressedChunk))) {
                    List<ExcelRowData> chunkRows = objectMapper.readValue(gis, new TypeReference<List<ExcelRowData>>() {});
                    allRows.addAll(chunkRows);
                }
            }
            return allRows;
        } catch (IOException | DataAccessException e) {
            throw new CustomExceptions.FileProcessingException("Failed to reconstruct cached data", e);
        }
    }



    public void saveRowsToRedis(String requestId, List<ExcelRowData> rows) {
        if (rows == null || rows.isEmpty()) return;
        try {
            int chunkSize = 5000;
            int totalRows = rows.size();
            int totalChunks = (int) Math.ceil((double) totalRows / chunkSize);

            for (int i = 0; i < totalChunks; i++) {
                int start = i * chunkSize;
                int end = Math.min(start + chunkSize, totalRows);
                List<ExcelRowData> chunk = rows.subList(start, end);

                try (ByteArrayOutputStream baos = new ByteArrayOutputStream();
                     GZIPOutputStream gos = new GZIPOutputStream(baos)) {
                    objectMapper.writeValue(gos, chunk);
                    gos.finish();
                    String chunkKey = "DATA_CHUNK_" + requestId + "_" + i;
                    redisTemplate.opsForValue().set(chunkKey, baos.toByteArray(), 1, TimeUnit.HOURS);
                }
            }

            Map<String, Object> meta = new HashMap<>();
            meta.put("totalChunks", totalChunks);
            meta.put("totalRows", totalRows);
            byte[] metaBytes = objectMapper.writeValueAsBytes(meta);
            redisTemplate.opsForValue().set("DATA_META_" + requestId, metaBytes, 1, TimeUnit.HOURS);

        } catch (IOException | DataAccessException e) {
            throw new CustomExceptions.RedisOperationException("Failed to cache large dataset", e);
        }
    }

    public byte[] getFileBytes(String reqId, String type) {
        try {
            return redisTemplate.opsForValue().get("FILE_" + reqId + "_" + type);
        } catch (DataAccessException e) {
            return null;
        }
    }

    public void saveErrorFileToRedis(String reqId, byte[] fileData) {
        try {
            redisTemplate.opsForValue().set("FILE_" + reqId + "_ERROR", fileData, 30, TimeUnit.MINUTES);
        } catch (DataAccessException e) {
            log.error("REDIS_WRITE_FAIL | ReqID: {} | Could not save error file to cache.", reqId);
        }
    }
}
package com.fincore.VoucherService.Service.validation;

import com.fasterxml.jackson.annotation.*;
import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.VoucherService.Dto.BulkUploadStateDto;
import com.fincore.VoucherService.Dto.ExcelRowData;
import com.fincore.VoucherService.Exception.CustomExceptions;
import com.fincore.VoucherService.Service.ValidationMasterService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.apache.poi.ss.usermodel.*;
import org.slf4j.MDC;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.context.annotation.Lazy;
import org.springframework.dao.DataAccessException;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Service;

import java.io.*;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.StandardCopyOption;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;
import java.util.stream.Collectors;
import com.fincore.VoucherService.Dto.ParsingResult;



/**
 * Handles high-performance streaming parsing and multi-stage validation.
 * Optimized to prevent OOM errors by offloading large datasets to Redis with GZIP compression.
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class VoucherBulkValidationService {

    private VoucherRuleValidator voucherRuleValidator;

    private final ExcelStreamingParser excelParser;
    private final VoucherRuleValidator ruleValidator;
    private final ValidationStateManager stateManager;
    private final ValidationReportGenerator reportGenerator;
    private final ObjectMapper objectMapper;

    // ==================================================================================
    // GLOBAL SECURITY CONFIGURATION
    // ==================================================================================
    static {
        // Prevents Zip Bomb / Decompression attacks by enforcing a strict inflation ratio
        org.apache.poi.openxml4j.util.ZipSecureFile.setMinInflateRatio(0.001);

        // Prevents massive file memory allocation attacks
        org.apache.poi.openxml4j.util.ZipSecureFile.setMaxEntrySize(100 * 1024 * 1024); // 100MB Max
    }



    @Autowired
    @Qualifier("byteArrayRedisTemplate")
    private RedisTemplate<String, byte[]> redisTemplate;

    @Autowired
    @Lazy
    private VoucherBulkValidationService self;

    private BulkUploadStateDto getStatusFromRedis(String reqId) {
        try {
            byte[] json = redisTemplate.opsForValue().get("BULK_STATUS_" + reqId);
            if (json == null) return null;
            return objectMapper.readValue(json, BulkUploadStateDto.class);
        } catch (IOException | DataAccessException e) {
            log.error("REDIS_READ_FAIL | ReqID: {} | Type: {}", reqId, e.getClass().getSimpleName());
            return null;
        }
    }


    // ==================================================================================
    // 2. UPLOAD INITIALIZATION (Security & Storage)
    // ==================================================================================

    public String initiateValidation(org.springframework.web.multipart.MultipartFile file, LocalDate postingDate) throws IOException {

        String filename = file.getOriginalFilename();
        long fileSize = file.getSize();

        // FIX 1: Lower the minimum size to 1 KB (allows small templates to pass)
        if (fileSize < 1024) {
            log.error("UPLOAD_SECURITY_DENIED | Status: File too small (Size: {} bytes)", fileSize);
            throw new CustomExceptions.FileProcessingException("File is too small. Minimum allowed size is 1 KB.");
        }

        if (fileSize > 50 * 1024 * 1024) {
            log.error("UPLOAD_SECURITY_DENIED | Status: File size out of bounds (Size: {} bytes)", fileSize);
            throw new CustomExceptions.FileProcessingException("File size cannot exceed 50MB.");
        }

        if (filename == null || filename.isBlank()) {
            throw new CustomExceptions.FileProcessingException("Filename cannot be empty.");
        }

        if (filename.length() > 35) {
            log.error("UPLOAD_SECURITY_DENIED | Status: Filename exceeds 35 characters");
            throw new CustomExceptions.FileProcessingException("File name length cannot exceed 35 characters.");
        }

        if (filename.indexOf('.') != filename.lastIndexOf('.')) {
            log.error("UPLOAD_SECURITY_DENIED | Status: Multiple extensions detected");
            throw new CustomExceptions.FileProcessingException("Files with multiple extensions are strictly prohibited.");
        }

        // FIX 3: Add \\s (spaces) and \\(\\) (parentheses) to the regex so it accepts 'Template (1).xlsx'
        if (!filename.matches("^[a-zA-Z0-9_\\-\\s\\(\\)]+\\.(xlsx|xls)$")) {
            log.error("UPLOAD_SECURITY_DENIED | Status: Invalid characters or extension in filename");
            throw new CustomExceptions.FileProcessingException("Invalid file name. Only .xls and .xlsx files with alphanumeric characters, spaces, hyphens, underscores, and parentheses are allowed.");
        }


        String mimeType = file.getContentType();
        // FIX 4: Add generic fallback MIME types. Sometimes Windows/Browsers send octet-stream or zip for Excel files.
        if (mimeType == null || (
                !"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet".equals(mimeType) &&
                        !"application/vnd.ms-excel".equals(mimeType) &&
                        !"application/octet-stream".equals(mimeType) &&
                        !"application/zip".equals(mimeType))) {
            log.error("UPLOAD_SECURITY_DENIED | Status: Invalid MIME Type: {}", mimeType);
            throw new CustomExceptions.FileProcessingException("Invalid file format. Detected MIME type does not match Excel.");
        }

        String requestId = UUID.randomUUID().toString();

      

        // --- ADD THIS: EXPLICIT SECURE FILE PERMISSIONS ---
        Path tempFile;
        try {
            // Check if running on Linux/Unix to apply strict POSIX permissions (rw-------)
            if (java.nio.file.FileSystems.getDefault().supportedFileAttributeViews().contains("posix")) {
                java.nio.file.attribute.FileAttribute<java.util.Set<java.nio.file.attribute.PosixFilePermission>> attr =
                        java.nio.file.attribute.PosixFilePermissions.asFileAttribute(java.nio.file.attribute.PosixFilePermissions.fromString("rw-------"));
                tempFile = Files.createTempFile("UPLOAD_" + requestId + "_", ".tmp", attr);
            } else {
                // Fallback for Windows environments
                tempFile = Files.createTempFile("UPLOAD_" + requestId + "_", ".tmp");
                tempFile.toFile().setReadable(true, true);
                tempFile.toFile().setWritable(true, true);
                tempFile.toFile().setExecutable(false);
            }
        } catch (IOException e) {
            throw new CustomExceptions.FileProcessingException("Failed to allocate secure storage for upload.");
        }

        // The variable is renamed to uploadStream to guarantee no naming collisions
        try (InputStream uploadStream = file.getInputStream()) {
            Files.copy(uploadStream, tempFile, StandardCopyOption.REPLACE_EXISTING);
        } catch (IOException e) {
            log.error("TEMP_FILE_CREATE_FAIL | ReqID: {} | Status: Disk IO failure", requestId);
            throw new CustomExceptions.FileProcessingException("Failed to secure uploaded file on disk.");
        }

        BulkUploadStateDto state = new BulkUploadStateDto();
        state.setRequestId(requestId);
        state.setStatus("PROCESSING");
        state.setCurrentStage(1);
        state.setMessage("Initializing Upload...");
        state.setTotalRows(0);
        stateManager.saveStatusToRedis(requestId, state);

        log.info("VALIDATION_INIT | ReqID: {} | Status: Temporary storage allocated", requestId);
        self.processAsync(requestId, tempFile.toString(), filename, postingDate);
        return requestId;
    }


    // ==================================================================================
    // 3. ORCHESTRATION ENGINE (The Async Loop)
    // ==================================================================================

    @Async("bulkExecutor")
    public void processAsync(String requestId, String tempFilePath, String filename, LocalDate postingDate) {
        MDC.put("requestId", requestId);
        long startTime = System.currentTimeMillis();
        File tempFile = new File(tempFilePath);

        try {
            stateManager.updateState(requestId, s -> s.setMessage("Parsing File..."));
            ParsingResult parsingResult;

            try (InputStream is = new FileInputStream(tempFile)) {
                // Directly parse as Excel
                parsingResult = excelParser.parseExcelStream(is, postingDate);
            }

            List<ExcelRowData> parsedRows = parsingResult.rows;
            if (parsedRows == null || parsedRows.isEmpty()) {
                throw new CustomExceptions.InvalidDataException("File data is empty. No transaction rows found.");
            }

            stateManager.updateState(requestId, s -> {
                s.setTotalRows(parsedRows.size());
                s.setMessage("Validating Formats...");
            });

            // DELEGATE: Stage 1 (Format Check)
            ruleValidator.runFormatCheck(parsedRows);
            if (parsedRows.stream().anyMatch(ExcelRowData::hasErrors)) {
                failRequest(requestId, parsedRows, "Format Validation Failed", 1, parsingResult.hasProductColumn);
                return;
            }

            // DELEGATE: Stage 2 (Database Check)
            stateManager.updateState(requestId, s -> {
                s.setCurrentStage(2);
                s.setMessage("Checking Database...");
            });
            ruleValidator.runDbCheck(parsedRows);
            if (parsedRows.stream().anyMatch(ExcelRowData::hasErrors)) {
                failRequest(requestId, parsedRows, "Database Validation Failed", 2, parsingResult.hasProductColumn);
                return;
            }

            // DELEGATE: Stage 3 (Balance Check)
            stateManager.updateState(requestId, s -> {
                s.setCurrentStage(3);
                s.setMessage("Checking Balances...");
            });
            ruleValidator.runBalanceCheck(parsedRows);
            if (parsedRows.stream().anyMatch(ExcelRowData::hasErrors)) {
                failRequest(requestId, parsedRows, "Debit/Credit Balance Mismatch", 3, parsingResult.hasProductColumn);
                return;
            }


            log.info("VALIDATION_SUCCESS | ReqID: {} | Duration: {}ms", requestId, (System.currentTimeMillis() - startTime));

            // Removed isCsv flag from the method call
            completeRequest(requestId, parsedRows, postingDate, parsingResult.hasProductColumn);

        }
        // --- ALL ORIGINAL CATCH BLOCKS RESTORED EXACTLY ---
        catch (CustomExceptions.InvalidDataException e) {
            log.warn("EMPTY_DATA_REJECTED | ReqID: {} | Reason: {}", requestId, e.getMessage());
            handleAsyncCrash(requestId, e.getMessage());
        }
        catch (FileNotFoundException e) {
            handleAsyncCrash(requestId, "System Error: File not found in temporary storage.");
        } catch (IOException e) {
            handleAsyncCrash(requestId, "System Error: Failed to read file content.");
        } catch (DateTimeParseException e) {
            log.error("DATE_PARSING_FAIL | ReqID: {} | Status: Invalid row date format", requestId);
            handleAsyncCrash(requestId, "Validation Failed: Incorrect date format detected in rows.");
        } catch (NumberFormatException e) {
            log.error("AMOUNT_PARSING_FAIL | ReqID: {} | Status: Numeric format error", requestId);
            handleAsyncCrash(requestId, "Validation Failed: Non-numeric values found in amount column.");
        } catch (DataAccessException e) {
            log.error("REDIS_OR_DB_UNAVAILABLE | ReqID: {} | Status: Backend connection failure", requestId);
            handleAsyncCrash(requestId, "System temporarily unavailable. Please try again later.");
        } catch (NullPointerException | ArrayIndexOutOfBoundsException e) {
            log.error("INTERNAL_LOGIC_ERROR | ReqID: {} | Type: {}", requestId, e.getClass().getSimpleName());
            handleAsyncCrash(requestId, "Internal system failure during processing.");
        }
        catch (Throwable t) {
            log.error("FATAL_SYSTEM_ERROR | ReqID: {} | Type: {}", requestId, t.getClass().getSimpleName(), t);
            handleAsyncCrash(requestId, "A critical system error occurred during processing.");
        }
        finally {
            if (tempFile.exists() && !tempFile.delete()) {
                log.warn("CLEANUP_WARN | Path: {} | Status: Temp file purge failed", tempFilePath);
            }
            MDC.clear();
        }
    }


    // ==================================================================================
    // 4. COMPLETION & ERROR DELEGATION
    // ==================================================================================
    private void failRequest(String reqId, List<ExcelRowData> rows, String msg, int stage, boolean hasProductColumn) throws IOException {
        log.warn("VALIDATION_FAILED | ReqID: {} | Reason: {}", reqId, msg);

        // Let the Report Generator build the Excel
        byte[] excel = reportGenerator.generateErrorExcelFast(rows, hasProductColumn);

        // Let the State Manager save it to Redis
        stateManager.saveErrorFileToRedis(reqId, excel);

        stateManager.updateState(reqId, s -> {
            s.setStatus("ERROR");
            s.setMessage(msg);
            s.setCurrentStage(stage);
            s.setErrorCount(rows.stream().filter(ExcelRowData::hasErrors).count());
            s.setHasErrorFile(true);
        });
    }

    private void completeRequest(String reqId, List<ExcelRowData> rows, LocalDate pDate, boolean hasProductColumn) throws IOException {
        stateManager.saveRowsToRedis(reqId, rows);

        List<Map<String, Object>> preview = rows.stream().limit(2000).map(this::mapToPreview).collect(Collectors.toList());

        stateManager.updateState(reqId, s -> {
            s.setCurrentStage(4);
            s.setStatus("SUCCESS");
            s.setMessage("Validation Successful");
            s.setHasSuccessFile(false);
            s.setHasProductColumn(hasProductColumn);
            try {
                s.setPreviewDataJson(objectMapper.writeValueAsString(preview));
            } catch (JsonProcessingException ignored) {}
        });
    }


    private void handleAsyncCrash(String requestId, String message) {
        log.error("ASYNC_PROCESS_CRASH | ReqID: {} | Reason: {}", requestId, message);
        stateManager.updateState(requestId, s -> {
            s.setStatus("ERROR");
            s.setMessage(message);
            s.setHasErrorFile(false);
        });
    }

    private Map<String, Object> mapToPreview(ExcelRowData r) {
        Map<String, Object> m = new java.util.HashMap<>();
        m.put("id", r.rowIndex);
        m.put("branch", r.branch);
        m.put("currency", r.currency);
        m.put("cgl", r.cgl);
        m.put("amount", r.amount != null ? r.amount.toString() : "");
        m.put("txnType", r.txnType);
        m.put("remarks", r.remarks);
        m.put("productCode", r.productCode);
        return m;
    }


    // Pass-through methods for Controllers
    public BulkUploadStateDto getState(String reqId) {
        return stateManager.getStatusFromRedis(reqId);
    }

    public byte[] getFileBytes(String reqId, String type) {
        return stateManager.getFileBytes(reqId, type);
    }

}


package com.fincore.VoucherService.Service.validation;


import com.fincore.VoucherService.Dto.ExcelRowData;
import com.fincore.VoucherService.Service.ValidationMasterService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.math.BigDecimal;
import java.util.List;
import java.util.Set;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.atomic.AtomicReference;

@Service
public class VoucherRuleValidator {

    @Autowired
    private final ValidationMasterService validationMasterService;

    public VoucherRuleValidator(ValidationMasterService validationMasterService) {
        this.validationMasterService = validationMasterService;
    }


    // ==================================================================================
    // 4. VALIDATION STAGES
    // ==================================================================================

    public void runFormatCheck(List<ExcelRowData> rows) {
        rows.parallelStream().forEach(d -> {

            // 1. Safely grab the value, remove all spaces, and make it uppercase
            String rawType = (d.txnType != null) ? d.txnType.trim().toUpperCase() : "";

            // 2. Check the cleaned value and instantly standardize it to full words
            if (rawType.equals("CR") || rawType.equals("CREDIT")) {
                d.txnType = "Credit";
            }
            else if (rawType.equals("DR") || rawType.equals("DEBIT")) {
                d.txnType = "Debit";
            }
            else {
                synchronized(d.formatErrors) {
                    d.formatErrors.add("Transaction type must be 'CR' or 'DR' (Case insensitive).");
                }
            }


            // Amount
            if (d.amount == null || d.amount.compareTo(BigDecimal.ZERO) <= 0) {
                synchronized(d.formatErrors) { d.formatErrors.add("Amount must be greater than 0."); }
            } else if (d.amount.precision() > 20 || d.amount.scale() > 4) {
                synchronized(d.formatErrors) { d.formatErrors.add("Exceeded maximum 16 digits or 4 decimal places."); }
            }


            // Product Code
            if (d.productCode != null && !d.productCode.isEmpty() && !d.productCode.equals("A") && !d.productCode.matches("^[0-9]{1,8}$")) {
                synchronized(d.formatErrors) { d.formatErrors.add("Product code must be up to 8 digits or left blank."); }
            }

            // Remarks (Alphanumeric, single spaces, and specific special characters)
            if (d.remarks == null || d.remarks.trim().length() < 2 || d.remarks.trim().length() > 30) {
                synchronized(d.formatErrors) {
                    d.formatErrors.add("Remarks must be 2-30 characters.");
                }
            } else if (d.remarks.startsWith(" ") || d.remarks.contains("  ")) {
                synchronized(d.formatErrors) {
                    d.formatErrors.add("Remarks cannot start with a space or contain consecutive spaces.");
                }
            } else if (!d.remarks.matches("^[a-zA-Z0-9 /&(),.\\-]+$")) {
                synchronized(d.formatErrors) {
                    d.formatErrors.add("Allowed 2-30 chars: Alphanumeric, spaces, and / & ( ) , . -");
                }
            }

            // Currency
            if (d.currency == null || d.currency.length() != 3) {
                synchronized(d.formatErrors) { d.formatErrors.add("Currency code must be exactly 3 characters."); }
            }

            // CGL (Strictly 10 digits)
            if (d.cgl == null || d.cgl.isEmpty()) {
                synchronized(d.formatErrors) { d.formatErrors.add("CGL is mandatory."); }
            } else if (!d.cgl.matches("^[0-9]{10}$")) {
                synchronized(d.formatErrors) { d.formatErrors.add("CGL must be exactly 10 digits."); }
            }

            // Branch (Strictly 5 alphanumeric characters)
            if (d.branch == null || d.branch.trim().isEmpty()) {
                synchronized(d.formatErrors) { d.formatErrors.add("Branch code is mandatory."); }
            } else if (!d.branch.matches("^[a-zA-Z0-9]{5}$")) {
                synchronized(d.formatErrors) { d.formatErrors.add("Branch code must be exactly 5 alphanumeric characters."); }
            }
        });
    }

    public void runDbCheck(List<ExcelRowData> rows) {
        Set<String> validBranches = validationMasterService.getAllActiveBranches();
        Set<String> validCurrs = validationMasterService.getAllActiveCurrencies();
        Set<String> validCgls = validationMasterService.getAllActiveCgls();

        rows.parallelStream().forEach(d -> {
            if (d.branch != null && !d.branch.isEmpty() && !validBranches.contains(d.branch))
                d.dbErrors.add("Branch is inactive or not found: " + d.branch);
            if (d.currency != null && !d.currency.isEmpty() && !validCurrs.contains(d.currency))
                d.dbErrors.add("Currency is inactive or not found: " + d.currency);
            if (d.cgl != null && !d.cgl.isEmpty() && !validCgls.contains(d.cgl))
                d.dbErrors.add("CGL is inactive or not found: " + d.cgl);
        });
    }


    /**
     * Rule 5: Balance Integrity Logic.
     * Uses LongAdder with 10^4 scale shift to perform precise integer arithmetic
     * on parallel streams, preventing floating-point drift in large batches.
     */
    public void runBalanceCheck(List<ExcelRowData> rows) {
    ConcurrentHashMap<String, AtomicReference<BigDecimal>> balanceMap = new ConcurrentHashMap<>();
        ConcurrentHashMap<String, Boolean> branchHasDebit = new ConcurrentHashMap<>();
        ConcurrentHashMap<String, Boolean> branchHasCredit = new ConcurrentHashMap<>();

        // Pass 1: Aggregate totals and check for presence
        rows.parallelStream().forEach(d -> {
            if (d.branch == null || d.currency == null || d.cgl == null || d.amount == null || d.txnType == null) return;

            // Track Debit/Credit Presence per Branch
            if ("Debit".equalsIgnoreCase(d.txnType)) branchHasDebit.put(d.branch, true);
            if ("Credit".equalsIgnoreCase(d.txnType)) branchHasCredit.put(d.branch, true);

            // Calculate Balance Groupings
            boolean isCredit = "Credit".equalsIgnoreCase(d.txnType);
            BigDecimal finalVal = isCredit ? d.amount.negate() : d.amount;

            String type = d.cgl.startsWith("5") ? "MEMO" : "NORMAL";
            String balKey = d.branch + "_" + d.currency + "_" + type;

            // Thread-safe BigDecimal addition without scaling or overflow risks
            balanceMap.computeIfAbsent(balKey, k -> new AtomicReference<>(BigDecimal.ZERO))
                    .updateAndGet(curr -> curr.add(finalVal));
        });

        // Pass 2: Apply the simple, generic error messages to the rows
        rows.parallelStream().forEach(d -> {
            if (d.branch == null || d.currency == null || d.cgl == null || d.amount == null || d.txnType == null) return;

            Boolean hasDeb = branchHasDebit.getOrDefault(d.branch, false);
            Boolean hasCred = branchHasCredit.getOrDefault(d.branch, false);

            String type = d.cgl.startsWith("5") ? "MEMO" : "NORMAL";
            String balKey = d.branch + "_" + d.currency + "_" + type;
            AtomicReference<BigDecimal> adder = balanceMap.get(balKey);

            synchronized (d.balErrors) {
                // 1. Debit/Credit Presence Check
                if ((!hasDeb || !hasCred) && !d.balErrors.contains("Branch must have at least one Debit and one Credit entry.")) {
                    d.balErrors.add("Branch must have at least one Debit and one Credit entry.");
                }

                // 2. Balance Math Check (Using BigDecimal's compareTo)
                if (adder != null && adder.get().compareTo(BigDecimal.ZERO) != 0 && !d.balErrors.contains("Branch, Currency, and CGL-wise balance mismatch.")) {
                    d.balErrors.add("Branch, Currency, and CGL-wise balance mismatch.");
                }
            }
        });
    }
}
package com.fincore.VoucherService.Service;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.dao.DataAccessException;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Service;

import java.util.HashSet;
import java.util.List;
import java.util.Set;

/**
 * Loads active master records into memory-efficient HashSets for O(1) validation lookups.
 * Utilizes optimized JDBC fetch sizes to handle high-volume data transfers from Oracle.
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class ValidationMasterService {

    @Autowired
    @Qualifier("oracleJdbcTemplate")
    private JdbcTemplate jdbcTemplate;

    /**
     * Fetches all active branch codes.
     * Uses a fetchSize of 5000 to minimize network round-trips for large branch networks.
     */
    public Set<String> getAllActiveBranches() {
        long start = System.currentTimeMillis();
        String sql = "SELECT CODE FROM BRANCH_MASTER WHERE STATUS = 1";

        try {
            List<String> list = jdbcTemplate.query(con -> {
                var ps = con.prepareStatement(sql);
                ps.setFetchSize(5000);
                return ps;
            }, (rs, rowNum) -> rs.getString(1));

            log.info("MASTER_DATA_LOADED | Type: BRANCHES | Count: {} | Duration: {}ms", list.size(), System.currentTimeMillis() - start);
            return new HashSet<>(list);

        } catch (DataAccessException e) {
            log.error("MASTER_DATA_FETCH_FAIL | Type: BRANCHES | Reason: {}", e.getMessage());
            return new HashSet<>(); // Returning empty set to trigger validation failure safely
        }
    }

    /**
     * Fetches all active currency codes.
     * Uses a fetchSize of 1000 for standard currency volume.
     */
    public Set<String> getAllActiveCurrencies() {
        long start = System.currentTimeMillis();
        String sql = "SELECT CURRENCY_CODE FROM CURRENCY_MASTER WHERE FLAG = 1";

        try {
            List<String> list = jdbcTemplate.query(con -> {
                var ps = con.prepareStatement(sql);
                ps.setFetchSize(1000);
                return ps;
            }, (rs, rowNum) -> rs.getString(1));

            log.info("MASTER_DATA_LOADED | Type: CURRENCIES | Count: {} | Duration: {}ms", list.size(), System.currentTimeMillis() - start);
            return new HashSet<>(list);

        } catch (DataAccessException e) {
            log.error("MASTER_DATA_FETCH_FAIL | Type: CURRENCIES | Reason: {}", e.getMessage());
            return new HashSet<>();
        }
    }

    /**
     * Fetches all active CGL numbers.
     * Uses a fetchSize of 2000 to balance memory and speed for ledger data.
     */
    public Set<String> getAllActiveCgls() {
        long start = System.currentTimeMillis();
        String sql = "SELECT CGL_NUMBER FROM CGL_MASTER WHERE STATUS = 1";

        try {
            List<String> list = jdbcTemplate.query(con -> {
                var ps = con.prepareStatement(sql);
                ps.setFetchSize(2000);
