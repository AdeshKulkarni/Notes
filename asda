@RestController
@RequestMapping("/api/voucher")
@RequiredArgsConstructor
@Slf4j
public class VoucherQueryController {



    private final VoucherQueryService queryService;
    private final JsEodMasterService jsEodMasterService;
    private final RequestVoucherService requestVoucherService;
    private final JwtUtil jwtUtil;



    /**
     * Safeguard: Forces pagination if batch rows exceed 2000 to avoid Server OOM.
     */
    @GetMapping("/by-batch/{batchId}")
    public ResponseEntity<?> getRequestsByBatchId(@PathVariable String batchId) {
        long count = queryService.getRequestCountByBatchId(batchId);
        if (count > 2000) return ResponseEntity.status(HttpStatus.PAYLOAD_TOO_LARGE).body(Map.of("error", "Batch too large.", "suggestion", "/api/voucher/by-batch-paginated/" + batchId));
        return ResponseEntity.ok(queryService.getRequestsByBatchId(batchId));
    }



    @GetMapping("/by-batch-paginated/{batchId}")
    public ResponseEntity<?> getRequestsByBatchIdPaginated(@PathVariable String batchId, @RequestParam(defaultValue = "0") int page, @RequestParam(defaultValue = "10") int size) {
        return ResponseEntity.ok(queryService.getRequestsByBatchIdPaginated(batchId, PageRequest.of(page, size)));
    }

    @GetMapping("/download-batch/{batchId}")
    public ResponseEntity<?> downloadBatchExcel(@PathVariable String batchId, @RequestHeader("Authorization") String token) {
        try {
            if (!queryService.isUserAuthorizedForBatch(batchId, jwtUtil.getUserIdFromToken(token.substring(7)), jwtUtil.getUserRoleFromToken(token.substring(7)))) {
                return ResponseEntity.status(HttpStatus.FORBIDDEN).body(Map.of("message", "You are not authorized to view this batch."));
            }

            byte[] fileData = queryService.generateBatchExcel(batchId);
            org.springframework.http.HttpHeaders headers = new org.springframework.http.HttpHeaders();
            headers.setCacheControl(org.springframework.http.CacheControl.noCache().mustRevalidate().sMaxAge(java.time.Duration.ZERO));
            headers.set(org.springframework.http.HttpHeaders.CONTENT_DISPOSITION, "attachment; filename=\"Batch_" + batchId + ".xlsx\"");
            headers.set(org.springframework.http.HttpHeaders.CONTENT_TYPE, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            return ResponseEntity.ok().headers(headers).body(fileData);

        } catch (CustomExceptions.InvalidDataException e) {
            // FIX: Return the exact "No records found" message as JSON
            return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(Map.of("message", e.getMessage()));
        } catch (Exception e) {
            log.error("DOWNLOAD_ERROR | Batch: {} | Reason: {}", batchId, e.getMessage());
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(Map.of("message", "Failed to generate Excel file."));
        }
    }

    @GetMapping("/pending-requests")
    public List<JournalRequest> getPendingRequests(@RequestHeader("Authorization") String token) {
        return queryService.getPendingRequests(jwtUtil.getUserIdFromToken(token), jwtUtil.getUserRoleFromToken(token));
    }

    @GetMapping("/checker/pending-approvals")
    public ResponseEntity<List<Map<String, Object>>> getPendingApprovals(@RequestHeader("Authorization") String token) {
        Integer userRole = jwtUtil.getUserRoleFromToken(token);
        String userId = jwtUtil.getUserIdFromToken(token);
        return ResponseEntity.ok(queryService.getPendingBatchesForChecker(userRole, userId));
    }

    // ==================================================================================
    // 2. DASHBOARDS & SUMMARIES
    // ==================================================================================

    @GetMapping("/all-requests-summary")
    public ResponseEntity<List<Map<String, Object>>> getAllRequestsSummary(@RequestHeader("Authorization") String token) {
        String userId = jwtUtil.getUserIdFromToken(token);
        return ResponseEntity.ok(queryService.getAllRequestsSummary(userId));
    }

    @GetMapping("/workflow-history/{batchId}")
    public ResponseEntity<List<Map<String, Object>>> getWorkflowHistory(@PathVariable String batchId) {
        return ResponseEntity.ok(queryService.getWorkflowHistory(batchId));
    }

    @GetMapping("/batch-summary/{batchId}")
    public ResponseEntity<Map<String, Object>> getBatchSummaryDetails(@PathVariable String batchId) {
        return ResponseEntity.ok(queryService.getBatchSummaryDetails(batchId));
    }


    // ==================================================================================
    // 3. UTILITIES & METADATA
    // ==================================================================================

    @GetMapping("/current-posting-date")
    public String getCurrentPostingDate() { return queryService.getCurrentPostingDate().format(DateTimeFormatter.ISO_LOCAL_DATE); }

    @GetMapping("/eod_status")
    public ResponseEntity<List<JsEodMasterDTO>> getEodStatus() { return new ResponseEntity<>(jsEodMasterService.getAllData(), HttpStatus.OK); }

    @GetMapping("/filter")
    public ResponseEntity<List<RequestVoucher>> getFilteredVouchers(@RequestParam(required = false) String category, @RequestParam(required = false) String role, @RequestParam(required = false) @DateTimeFormat(pattern = "yyyy-MM-dd") LocalDate date) {
        return ResponseEntity.ok(requestVoucherService.getFilteredVouchers(category, role, date));
    }

    @GetMapping("/workflow/steps/{workflowCode}")
    public ResponseEntity<List<Map<String, Object>>> getWorkflowSteps(@PathVariable String workflowCode) { return ResponseEntity.ok(queryService.getWorkflowSteps(workflowCode)); }

    @GetMapping("/active-roles")
    public ResponseEntity<Map<String, String>> getActiveRoles() { return ResponseEntity.ok(queryService.getActiveRoles()); }

    @GetMapping("/vid-details/{vid}")
    public ResponseEntity<Map<String, Object>> getVidDetails(@PathVariable String vid) { return ResponseEntity.ok(queryService.getVidDetails(vid)); }

