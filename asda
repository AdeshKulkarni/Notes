    private String sanitize(String value) {
        if (value == null) return "";
        if (value.startsWith("=") || value.startsWith("+") || value.startsWith("-") || value.startsWith("@")) return "'" + value;
        return value;
    }

    public byte[] generateErrorExcelFast(List<ExcelRowData> rows, boolean includeProduct) throws IOException {
        SXSSFWorkbook workbook = new SXSSFWorkbook(100);
        try {
            Sheet sheet = workbook.createSheet("Error Report");
            CellStyle errStyle = workbook.createCellStyle();
            Font f = workbook.createFont();
            f.setColor(IndexedColors.RED.getIndex());
            errStyle.setFont(f);

            Row h = sheet.createRow(0);
            List<String> headerList = new ArrayList<>(Arrays.asList(
                    "Branch*", "Currency*", "CGL*", "Amount*", "Type*", "Remarks*", "Product Code", "ERRORS"
            ));

            for (int i = 0; i < headerList.size(); i++) {
                h.createCell(i).setCellValue(headerList.get(i));
            }

            int idx = 1;
            for (ExcelRowData d : rows) {
                Row r = sheet.createRow(idx++);
                int col = 0;

                r.createCell(col++).setCellValue(sanitize(d.branch));
                r.createCell(col++).setCellValue(sanitize(d.currency));
                r.createCell(col++).setCellValue(sanitize(d.cgl));
                r.createCell(col++).setCellValue(d.amount != null ? d.amount.stripTrailingZeros().toPlainString() : "");
                r.createCell(col++).setCellValue(sanitize(d.txnType));
                r.createCell(col++).setCellValue(sanitize(d.remarks));
                r.createCell(col++).setCellValue(sanitize(d.productCode));

                Cell c = r.createCell(col);
                if (d.hasErrors()) {
                    c.setCellValue(d.getAllErrors());
                    c.setCellStyle(errStyle);
                }
            }
            ByteArrayOutputStream out = new ByteArrayOutputStream();
            workbook.write(out);
            return out.toByteArray();
        } finally {
            workbook.dispose();
            workbook.close();
        }
    }


