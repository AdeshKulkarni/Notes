    @Async("bulkExecutor")
    public void executeAsyncBatchCreation(String batchId, String journalPrefix, String requestId, String commonRemarks, String creatorId, Integer creatorRole,  String vid) {
        String lockKey = "LOCK_REQ_" + requestId;
        MDC.put("batchId", batchId);
        MDC.put("user", creatorId);


        Map<String, String> contextMap = MDC.getCopyOfContextMap();
        AtomicInteger successfulRowsCount = new AtomicInteger(0);

        log.info("ASYNC_BATCH_START | Batch: {} | Source: {}", batchId, requestId);
        long start = System.currentTimeMillis();

        try {
            // 2. IDEMPOTENCY
            jdbcTemplate.update("DELETE FROM VOUCHER_POSTING_DATA WHERE BATCH_ID = ?", batchId);
//            jdbcTemplate.update("DELETE FROM VOUCHER_POSTING WHERE BATCH_ID = ?", batchId);

            progressService.sendProgress(batchId, creatorId, 5, "PROCESSING", "Preparing Data...");

            List<ExcelRowData> cachedRows = validationStateManager.getValidRowsFromCache(requestId);

            if (cachedRows == null || cachedRows.isEmpty()) {
                log.error("CACHE_MISS | Batch: {} | Status: No valid rows found", batchId);
                progressService.sendProgress(batchId, creatorId, 0, "FAILED", "Data cache expired or empty.");
                return;
            }

            long totalRows = cachedRows.size();
            int batchSize = 5000;
            List<CompletableFuture<Void>> futures = new ArrayList<>();
            AtomicReference<BigDecimal> totalDebit = new AtomicReference<>(BigDecimal.ZERO);
            AtomicReference<BigDecimal> totalCredit = new AtomicReference<>(BigDecimal.ZERO);
            AtomicInteger completedChunks = new AtomicInteger(0);
            int totalChunks = (int) Math.ceil((double) totalRows / batchSize);

            // 3. PARALLEL CHUNKING
            for (int i = 0; i < totalRows; i += batchSize) {
                final int startIdx = i;
                final int endIdx = Math.min(i + batchSize, Math.toIntExact(totalRows));
                final List<ExcelRowData> chunk = new ArrayList<>(cachedRows.subList(startIdx, endIdx));

                CompletableFuture<Void> future = CompletableFuture.runAsync(() -> {
                            if (contextMap != null) MDC.setContextMap(contextMap);
                            try {
                                self.processChunkRaw(chunk, batchId, journalPrefix, commonRemarks, creatorId, creatorRole, startIdx, totalDebit, totalCredit);
                                successfulRowsCount.addAndGet(chunk.size());
                            } finally {
                                MDC.clear();
                            }
                        }, chunkWorkerExecutor)
                        .thenRun(() -> {
                            int done = completedChunks.incrementAndGet();
                            int percent = 5 + (done * 90 / totalChunks);
                            progressService.sendProgress(batchId, creatorId, percent, "PROCESSING", String.format("Writing records: %d of %d", Math.min(done * batchSize, totalRows), totalRows));
                        });
                futures.add(future);
            }

            CompletableFuture.allOf(futures.toArray(new CompletableFuture[0])).get(45, TimeUnit.MINUTES);


            progressService.sendProgress(batchId, creatorId, 100, "COMPLETED", "Batch Created Successfully");

            jdbcTemplate.update("""
                UPDATE VOUCHER_POSTING 
                SET BATCH_STATUS = 'P' 
                WHERE BATCH_ID = ? 
                AND (IS_EXECUTION_SCHEDULED = 'YES' OR IS_EXECUTION_SCHEDULED = 'NO')
                AND BATCH_STATUS = 'S'
            """, batchId);

            String nextStepSql = """
                    SELECT w.ALLOWED_ROLE_ID 
                    FROM VOUCHER_POSTING vp
                    JOIN WORKFLOW_TRANSITIONS w 
                      ON vp.WORKFLOW_CODE = w.WORKFLOW_CODE
                    WHERE vp.BATCH_ID = ? AND w.WORKFLOW_ORDER = 2
                """;

            // --- NEW: ROUTE NOTIFICATIONS AFTER BACKGROUND TASK COMPLETES ---
            String workflowCode = jdbcTemplate.queryForObject("SELECT WORKFLOW_CODE FROM VOUCHER_POSTING WHERE BATCH_ID = ?", String.class, batchId);
            String nextApproverRoleId = jdbcTemplate.queryForObject(nextStepSql, String.class, batchId);

//            notificationWriterService.createBatchSubmissionNotification(batchId, creatorId);

            // Notifies strictly using the TARGET_ROLE
            notificationWriterService.createNextStepApprovalNotification(batchId, nextApproverRoleId);

            log.info("BATCH_CREATION_FINISHED | Batch: {} | Rows: {}", batchId);


        }

        catch (Exception e) {
            log.error("BATCH_FATAL_ERROR | Batch: {} | Error: {}", batchId, e.getMessage());
            handleAsyncFailure(batchId, creatorId, requestId, "An internal error occurred.");
        } finally {
            // Clean up Redis...
            redisTemplate.delete(lockKey);
            MDC.clear();
        }
    }

    private void handleAsyncFailure(String batchId, String creatorId, String requestId, String message) {
        try {
            // Delete orphaned data rows
            jdbcTemplate.update("DELETE FROM VOUCHER_POSTING_DATA WHERE BATCH_ID = ?", batchId);

            // Revert master record to Error
            int updated = jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'ERROR' WHERE BATCH_ID = ?", batchId);

        } catch (DataAccessException e) {
            log.error("CLEANUP_CRITICAL_FAIL | Batch: {} | Cannot record failure state", batchId);
        }
        progressService.sendProgress(batchId, creatorId, 0, "FAILED", message);
        sendNotification(creatorId, null, "Batch creation Failed for Batch ID : " + batchId, batchId);
    }

    @Transactional(propagation = Propagation.REQUIRES_NEW)
    public void processChunkRaw(List<ExcelRowData> chunk ,
                                String batchId,
                                String journalPrefix,
                                String commonRemarks,
                                String creatorId,
                                Integer creatorRole,
                                int globalOffset,
                                AtomicReference<BigDecimal> globalDebit,
                                AtomicReference<BigDecimal> globalCredit) {

        // FIX: Removed POSTING_DATE from columns.
        // 11 explicit columns + 1 sequence = 12 total targets.
        // 11 explicit '?' placeholders match the 11 explicit columns.
        String sql = "INSERT INTO VOUCHER_POSTING_DATA (" +
                "REQ_ID, REQ_STATUS, REQ_DATE, CREATOR_ID, BATCH_ID, " +
                "JOURNAL_ID, REQ_BRANCH_CODE, REQ_CURRENCY, REQ_CGL, " +
                "REQ_AMOUNT, REQ_NARRATION, REQ_PRODUCT) " +
                "VALUES (VOUCHER_POSTING_DATA_SEQ.NEXTVAL, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";

        try {
            jdbcTemplate.batchUpdate(sql, new org.springframework.jdbc.core.BatchPreparedStatementSetter() {
                @Override
                public void setValues(java.sql.PreparedStatement ps, int i) throws java.sql.SQLException {
                    ExcelRowData r = chunk.get(i);

                    int globalIdx = globalOffset + i + 1;
                    String jId = journalPrefix + "-" + globalIdx;

                    // 1. Case-Insensitive Check for Credit
                    BigDecimal absAmt = (r.amount != null) ? r.amount.abs() : BigDecimal.ZERO;
                    String safeTxnType = r.txnType != null ? r.txnType.trim() : "";
                    boolean isCredit = "CR".equalsIgnoreCase(safeTxnType) || "CREDIT".equalsIgnoreCase(safeTxnType);
                    BigDecimal signedAmt = isCredit ? absAmt.negate() : absAmt;

                    // 2. PERFECTLY MAPPED SETTERS (Shifted to 11 parameters)
                    ps.setString(1, "P");                                                           // REQ_STATUS
                    ps.setTimestamp(2, java.sql.Timestamp.valueOf(LocalDateTime.now()));            // REQ_DATE
                    ps.setString(3, creatorId);                                                     // CREATOR_ID
                    ps.setString(4, batchId);                                                       // BATCH_ID
                    ps.setString(5, jId);                                                           // JOURNAL_ID
                    ps.setString(6, r.branch);                                                      // REQ_BRANCH_CODE
                    ps.setString(7, r.currency);                                                    // REQ_CURRENCY
                    ps.setString(8, r.cgl);                                                         // REQ_CGL
                    ps.setBigDecimal(9, signedAmt);                                                 // REQ_AMOUNT

                    // POSTING_DATE binding safely removed

                    ps.setString(10, r.remarks);                                                    // REQ_NARRATION (Shifted from 11)
                    ps.setString(11, r.productCode);                                                // REQ_PRODUCT (Shifted from 12)
                }

                @Override
                public int getBatchSize() {
                    return chunk.size();
                }
            });

            // 3. Update Thread-Safe Aggregates Case-Insensitively
            for (ExcelRowData r : chunk) {
                BigDecimal absAmt = (r.amount != null) ? r.amount.abs() : BigDecimal.ZERO;
                String safeTxnType = r.txnType != null ? r.txnType.trim() : "";

                if ("CR".equalsIgnoreCase(safeTxnType) || "CREDIT".equalsIgnoreCase(safeTxnType)) {
                    globalCredit.updateAndGet(curr -> curr.add(absAmt));
                } else {
                    globalDebit.updateAndGet(curr -> curr.add(absAmt));
                }
            }

        } catch (org.springframework.dao.DataAccessException e) {
            log.error("JDBC_BATCH_FAIL | Batch: {} | Offset: {} | Error: {}", batchId, globalOffset, e.getMessage());
            throw new CustomExceptions.DatabaseOperationException("Database integrity error during chunk insert", e);
        }

    }
    @Async("bulkExecutor")
    public void executeAsyncBatchProcessing(BulkProcessVoucherPostingDto dto, String executorId) {
        String batchId = dto.getBatchId();
        MDC.put("batchId", batchId);
        MDC.put("user", executorId);
        long start = System.currentTimeMillis();

        try {
            self.executeApprovalInTransaction(dto, executorId);
            log.info("BATCH_PROCESSING_DONE | Batch: {} | Status: {} | Duration: {}ms", batchId, dto.getStatus(), System.currentTimeMillis() - start);
        } catch (org.springframework.dao.PessimisticLockingFailureException e) {
            log.error("DATABASE_LOCK_TIMEOUT | Batch: {} | Status: GL_BALANCE row locked", batchId);
            handleAsyncApprovalError(batchId, executorId, dto.getStatus(), "System is busy. Please retry in 1 minute.");
        } catch (DataAccessException e) {
            log.error("PROCEDURE_EXEC_FAIL | Batch: {} | Type: {}", batchId, e.getClass().getSimpleName());
            handleAsyncApprovalError(batchId, executorId, dto.getStatus(), "Database execution error during approval.");
        } catch (Exception e) {
            log.error("INTERNAL_PROCESSING_FAULT | Batch: {} | Type: {}", batchId, e.getClass().getSimpleName());
            handleAsyncApprovalError(batchId, executorId, dto.getStatus(), "An internal logic error occurred.");
        } finally {
            MDC.clear();
        }
    }

    @Transactional(propagation = Propagation.REQUIRES_NEW)
    public void executeApprovalInTransaction(BulkProcessVoucherPostingDto dto, String executorId) {
        String batchId = dto.getBatchId();


        // FIX: Fetch both Creator and VID for logging
        Map<String, Object> postingInfo = jdbcTemplate.queryForMap(
                "SELECT CREATED_BY, VID_FK FROM VOUCHER_POSTING WHERE BATCH_ID = ?", batchId);
        String vid = (String) postingInfo.get("VID_FK");

        // FIX 2: Fetch Creator from VOUCHER_POSTING
        String creatorId = jdbcTemplate.queryForObject(
                "SELECT CREATED_BY FROM VOUCHER_POSTING WHERE BATCH_ID = ?", String.class, batchId);

        if (creatorId != null && creatorId.equalsIgnoreCase(executorId)) {
            log.error("SECURITY_VIOLATION | Self-approval attempt blocked | Batch: {} | User: {}", batchId, executorId);
            handleAsyncApprovalError(batchId, executorId, dto.getStatus(), "Security Violation: You cannot approve or reject your own batch.");
            return;
        }

        progressService.sendProgress(batchId, executorId, 20, "PROCESSING", "Executing Oracle Core Business Logic...");

        if (RequestStatus.ACCEPTED.equals(dto.getStatus())) {

            List<HdfsSyncDto> syncData = jdbcTemplate.execute(
                    "{call PROCESS_JOURNAL_BATCH(?, ?, ?, ?, ?)}",
                    (CallableStatementCallback<List<HdfsSyncDto>>) cs -> {
                        cs.setString(1, batchId);
                        cs.setString(2, executorId);
                        cs.setString(3, dto.getRemarks());
                        cs.setString(4, "A");
                        cs.registerOutParameter(5, -10);
                        cs.execute();
                        List<HdfsSyncDto> list = new ArrayList<>();
                        try (ResultSet rs = (ResultSet) cs.getObject(5)) {
                            while (rs.next()) {
                                list.add(new HdfsSyncDto(
                                        rs.getString("BRANCH"), rs.getString("CURRENCY"), rs.getString("CGL"),
                                        rs.getDate("BAL_DATE") != null ? rs.getDate("BAL_DATE").toLocalDate() : null,
                                        rs.getBigDecimal("NEW_BALANCE"), rs.getBigDecimal("NEW_INR_BALANCE")
                                ));
                            }
                        }
                        return list;
                    }
            );

            jdbcTemplate.update(
                    "UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'A', EXECUTED_AT = SYSTIMESTAMP, EXECUTOR_ID = ? WHERE BATCH_ID = ?",
                    executorId, batchId);

            // --- ADDED: LOG SYSTEM EXECUTION SUCCESS ---
            workflowEngine.logWorkflowAction(batchId, vid, "Execution Completed", "SYSTEM", "Automated background execution completed successfully.", null);

            try {
                hdfsSyncService.syncToDataLake(syncData);
            } catch (Exception hdfsEx) {
                log.error("HDFS_SYNC_FAIL | Batch: {} | Error: {} | Status: Background recovery queued", batchId, hdfsEx.getClass().getSimpleName());
                jdbcTemplate.update("INSERT INTO HDFS_SYNC_RETRY_QUEUE (BATCH_ID, STATUS) VALUES (?, 'P')", batchId);
            }

            progressService.sendProgress(batchId, executorId, 100, "COMPLETED", "Batch Approved Successfully");
            notificationWriterService.createBatchApprovedNotification(batchId, creatorId, executorId);

        } else if (RequestStatus.REJECTED.equals(dto.getStatus())) {

            jdbcTemplate.update(
                    "UPDATE VOUCHER_POSTING_DATA SET REQ_STATUS = 'R' WHERE BATCH_ID = ? AND REQ_STATUS = 'P'",
                    batchId);
            jdbcTemplate.update(
                    "UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'R', EXECUTED_AT = SYSTIMESTAMP, EXECUTOR_ID = ? WHERE BATCH_ID = ?",
                    executorId, batchId);

            progressService.sendProgress(batchId, executorId, 100, "COMPLETED", "Batch Rejected");
            notificationWriterService.createBatchRejectedNotification(batchId, creatorId, executorId, dto.getRemarks());
        }
    }

    private void handleAsyncApprovalError(String batchId, String executorId, RequestStatus actionStatus, String msg) {
        jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'P' WHERE BATCH_ID = ?", batchId);
        progressService.sendProgress(batchId, executorId, 0, "FAILED", msg);

        // --- ADDED: LOG SYSTEM EXECUTION FAILURE ---
           String vid = null;
        try {
            vid = jdbcTemplate.queryForObject("SELECT VID_FK FROM VOUCHER_POSTING WHERE BATCH_ID = ?", String.class, batchId);
        } catch (org.springframework.dao.EmptyResultDataAccessException e) {
            log.warn("VID not found for Batch: {}", batchId);
        }
        workflowEngine.logWorkflowAction(batchId, vid, "Execution Failed", "SYSTEM", msg, null);

        String actionName = (actionStatus == RequestStatus.ACCEPTED) ? "approve" : "reject";
        String notifMsg = String.format("Failed to %s Journal Batch '%s'. It has been returned to PENDING.", actionName, batchId);

        try {
            notificationWriterService.createNotification(executorId, null, notifMsg, "/voucher-view/" + batchId, batchId, "VoucherService");
        } catch (Exception e) {
            log.warn("NOTIFICATION_WARN | Batch: {} | Could not send failure notification", batchId);
        }
    }

    @Async("bulkExecutor")
    public void executeAsyncBatchCancellation(String batchId, String userId) {
        MDC.put("batchId", batchId);
        MDC.put("user", userId);
        long start = System.currentTimeMillis();

        try {
            progressService.sendProgress(batchId, userId, 20, "PROCESSING", "Purging Data Rows...");

            // Calls the Oracle PL/SQL procedure to handle massive deletes safely
            jdbcTemplate.execute("{call PURGE_JOURNAL_BATCH(?, ?)}", (CallableStatementCallback<Object>) cs -> {
                cs.setString(1, batchId);
                cs.setString(2, userId);
                cs.execute();
                return null;
            });

            logAudit(userId, "CANCEL_SUCCESS", "DELETE", "Purged Batch " + batchId);
            progressService.sendProgress(batchId, userId, 100, "COMPLETED", "Batch Deleted");
            sendNotification(userId, null, "Batch " + batchId + " deleted successfully.", batchId);

            log.info("BATCH_PURGE_COMPLETE | Batch: {} | Duration: {}ms", batchId, System.currentTimeMillis() - start);

        } catch (DataAccessException e) {
            log.error("PURGE_DB_ERROR | Batch: {} | Status: SQL operation failed | Cause: {}", batchId, e.getMessage());

            // This safely reverts the batch to 'P' (Pending) without crashing the thread
            jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'P' WHERE BATCH_ID = ?", batchId);

            progressService.sendProgress(batchId, userId, 0, "FAILED", "Delete Failed: System error or missing database procedure.");
        } finally {
            MDC.clear();
        }
    }

    // ==================================================================================
    // 4. UTILITY METHODS
    // ==================================================================================

    private void sendNotification(String userId, String roles, String message, String batchId) {
        try {
            notificationWriterService.createNotification(userId, roles, message, "/journal-view/" + batchId, batchId, "VoucherService");
        } catch (DataAccessException e) {
            log.warn("NOTIFICATION_WARN | Batch: {} | Status: Failed to persist notification", batchId);
        }
    }

    private void logAudit(String user, String action, String type, String val) {
        try {
            JournalLog l = new JournalLog();
            l.setUserId(user);
            l.setActionType(action);
            l.setChangeType(type);
            l.setNewValue(val.length() > 3900 ? val.substring(0, 3900) : val);
            l.setActionTime(LocalDateTime.now());
            voucherLogRepository.save(l);
        } catch (DataAccessException e) {
            log.error("AUDIT_LOG_FAIL | User: {} | Status: Persistence error", user);
        }
    }


}


