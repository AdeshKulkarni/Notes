

package com.fincore.VoucherService.Controllers;

import com.fincore.VoucherService.Dto.BranchDto;
import com.fincore.VoucherService.Service.BranchService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;


import java.util.Collections;
import java.util.List;
import java.util.Map;

/**
 * Exposes endpoints for branch master data retrieval and search.
 * Rule: Implements "Starts With" search logic to optimize Oracle Index Range Scans.
 */
@RestController
@RequestMapping("/api/branches-journal")
@RequiredArgsConstructor
@Slf4j
public class BranchController {

    private final BranchService branchService;

    /**
     * Endpoint to retrieve a complete map of branch codes to branch names.
     */
    @GetMapping("/map")
    public ResponseEntity<Map<String, String>> getBranchMap() {
        log.info("BRANCH_CONTROLLER_MAP_REQUEST | Action: Fetching all active branch mappings");
        Map<String, String> branchMap = branchService.getBranchCodeAndNameMap();
        return ResponseEntity.ok(branchMap);
    }

    /**
     * Endpoint to perform a PREFIX search for branches.
     * Logic: Returns results starting with the query string (e.g., '321' matches '32121').
     */
    @GetMapping("/search")
    public ResponseEntity<List<BranchDto>> searchBranches(@RequestParam String query) {
        // Log the prefix search initialization
        log.info("BRANCH_CONTROLLER_PREFIX_SEARCH | Query: {}", query);

        if (query == null || query.trim().isEmpty()) {
            // Preservation of empty list logic for blank inputs
            return ResponseEntity.ok(Collections.emptyList());
        }

        // Service layer now handles the "StartingWith" repository call
        List<BranchDto> results = branchService.searchBranches(query.trim());
        return ResponseEntity.ok(results);
    }
}


package com.fincore.VoucherService.Controllers;

