    private String calculateTimeSinceLastAction(String batchId) {
        Optional<VoucherWorkflow> latestAction =
                workflowRepository.findTopByBatchIdFkOrderByLastActionAtDesc(batchId);

        if (latestAction.isEmpty() || latestAction.get().getLastActionAt() == null) {
            return "0h 0m";
        }

        Duration duration = Duration.between(latestAction.get().getLastActionAt(), LocalDateTime.now());
        return duration.toHours() + "h " + duration.toMinutesPart() + "m";
    }


    public List<Map<String, Object>> getPendingBatchesForChecker(Integer userRole, String userId) {
        String sql = """
            SELECT 
                p.BATCH_ID, 
                p.VID_FK AS VID, 
                p.CREATED_BY AS CREATOR_ID, 
                p.CREATED_AT AS REQ_DATE, 
                p.COMMON_BATCH_REMARKS AS BATCH_REMARKS,
                p.RECORDS_COUNT AS TOTAL_ROWS, 
                p.SCHEDULED_TIME,
                w.WORKFLOW_STAGE, 
                w.WORKFLOW_CODE, 
                w.ESCALATION_TIME, 
                w.WORKFLOW_ORDER, 
                w.IS_FINAL_APPROVAL,
                COALESCE(u.FIRST_NAME || ' ' || u.LAST_NAME, p.CREATED_BY) AS CREATOR_NAME
            FROM VOUCHER_POSTING p
            INNER JOIN WORKFLOW_TRANSITIONS w ON p.PENDING_AT = w.WORKFLOW_ID
            LEFT JOIN USERS u ON p.CREATED_BY = u.USER_ID
            WHERE w.ALLOWED_ROLE_ID = ? AND p.BATCH_STATUS = 'P'
            AND NOT EXISTS (
                SELECT 1 FROM VOUCHER_WORKFLOW vw 
                WHERE vw.BATCH_ID_FK = p.BATCH_ID AND vw.LAST_ACTION_BY = ?
            )
            ORDER BY p.CREATED_AT DESC
        """;

        // 1. Fetch the data from Oracle and store it in a List
        List<Map<String, Object>> pendingList = jdbcTemplate.query(sql, (rs, rowNum) -> {
            Map<String, Object> map = new HashMap<>();
            map.put("batchId", rs.getString("BATCH_ID"));
            map.put("vid", rs.getString("VID"));
            map.put("creatorId", rs.getString("CREATOR_ID"));
            map.put("creatorName", rs.getString("CREATOR_NAME"));
            map.put("requestDate", rs.getTimestamp("REQ_DATE"));
            map.put("commonBatchRemarks", rs.getString("BATCH_REMARKS"));
            map.put("requestCount", rs.getLong("TOTAL_ROWS"));
            map.put("escalationTime", rs.getLong("ESCALATION_TIME"));
            map.put("workflowState", rs.getString("WORKFLOW_STAGE"));
            map.put("approvalWorkflow", rs.getString("WORKFLOW_CODE"));
            map.put("currentOrder", rs.getObject("WORKFLOW_ORDER"));
            map.put("isFinalApproval", rs.getString("IS_FINAL_APPROVAL"));
            return map;
        }, userRole, userId);

        // 2. Loop through the list, calculate the time, and inject it into the map
        for (Map<String, Object> row : pendingList) {
            String batchId = (String) row.get("batchId");

            // Calls the helper method you already added!
            String pendingTime = calculateTimeSinceLastAction(batchId);

            // Injects the new string into the JSON response
            row.put("timeSinceLastAction", pendingTime);
        }

        // 3. Return the completed list to the Controller
        return pendingList;
    }


    public List<Map<String, Object>> getAllRequestsSummary(String userId) {
        String sql = """
            SELECT 
                p.BATCH_ID, 
                p.VID_FK,
                p.CREATED_BY AS CREATOR_ID, 
                COALESCE(u.FIRST_NAME || ' ' || u.LAST_NAME, p.CREATED_BY) AS CREATOR_NAME,
                p.CREATED_AT AS REQ_DATE, 
                p.RECORDS_COUNT AS TOTAL_ROWS, 
                p.BATCH_STATUS, 
                w.WORKFLOW_STAGE, 
                w.WORKFLOW_CODE,
                w.WORKFLOW_ORDER
            FROM VOUCHER_POSTING p
            LEFT JOIN WORKFLOW_TRANSITIONS w ON p.PENDING_AT = w.WORKFLOW_ID
            LEFT JOIN USERS u ON p.CREATED_BY = u.USER_ID
            WHERE UPPER(TRIM(p.CREATED_BY)) = UPPER(TRIM(?)) -- SECURITY FIX: Only fetch batches owned by the logged-in user
            ORDER BY p.CREATED_AT DESC
        """;

        return jdbcTemplate.query(sql, (rs, rowNum) -> {
            Map<String, Object> map = new HashMap<>();
            map.put("batchId", rs.getString("BATCH_ID"));
            map.put("vid", rs.getString("VID_FK"));
            map.put("creatorId", rs.getString("CREATOR_ID"));
