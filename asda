import java.time.LocalDate;
import lombok.Data;

import java.time.LocalDateTime;
import java.util.List;

@Data
public class BatchPostingDto {

    @Data
    public static class JournalRequestRow {
        @NotNull
        private ChangeType changeType = ChangeType.ADD;


        private Long masterJournalId;


        private LocalDate postingDate;


        @jakarta.validation.constraints.NotBlank(message = "Branch is required")
        @jakarta.validation.constraints.Size(min = 5, max = 5, message = "Branch code must be exactly 5 characters")
        private String branch;


        @jakarta.validation.constraints.NotBlank(message = "Currency is required")
        @jakarta.validation.constraints.Size(min = 3, max = 3, message = "Currency must be exactly 3 characters")
        private String currency;

        @jakarta.validation.constraints.NotBlank(message = "CGL is required")
        @jakarta.validation.constraints.Pattern(regexp = "^\\d{10}$", message = "CGL must be exactly 10 digits")
        private String cgl;

        @jakarta.validation.constraints.NotNull(message = "Amount is required")
        @jakarta.validation.constraints.Digits(integer = 16, fraction = 4, message = "Amount cannot exceed 16 integer digits and 4 fractional digits")
        private BigDecimal amount;

        @jakarta.validation.constraints.Pattern(regexp = "^\\d{0,8}$", message = "Product Type must be numeric and up to 8 digits")
        private String productType;

        @jakarta.validation.constraints.NotBlank(message = "Remarks are required")
        @jakarta.validation.constraints.Pattern(
                regexp = "^[a-zA-Z0-9 \\-_]{2,30}$",
                message = "Remarks must be 2-30 alphanumeric characters, including spaces, hyphens, or underscores"
        )
        private String remarks;

        @Size(min = 1, max = 1)
        private String arFlag = "A";

        @Size(min = 1, max = 1)
        private String acClassification;
    }

    @jakarta.validation.constraints.Pattern(regexp = "^([a-zA-Z0-9 ]{2,30})?$", message = "Common remarks must be 2-30 alphanumeric characters and spaces only, if provided")
    private String commonBatchRemarks;

    @Valid
    @jakarta.validation.constraints.NotEmpty(message = "Batch must contain at least one row")
    private List<JournalRequestRow> rows;

    @com.fasterxml.jackson.annotation.JsonFormat(pattern = "yyyy-MM-dd HH:mm:ss")
    private LocalDateTime scheduledTime;

    // Assuming VID is passed from frontend to identify the voucher type
    @jakarta.validation.constraints.NotBlank(message = "VID is required")
    private String vid;

}


