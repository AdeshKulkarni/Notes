package com.fincore.VoucherService.Controllers;


import com.fincore.VoucherService.Exception.CustomExceptions;
import com.fincore.VoucherService.Models.JournalRequest;
import com.fincore.VoucherService.Service.core.VoucherCommandService;
import com.fincore.VoucherService.Service.core.VoucherWorkflowEngine;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;
import com.fincore.VoucherService.Dto.*;
import com.fincore.commonutilities.jwt.JwtUtil;
import jakarta.validation.Valid;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.io.IOException;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
@RestController
@RequestMapping("/api/voucher")
@RequiredArgsConstructor
@Slf4j
public class VoucherActionController {


    private final VoucherCommandService commandService;
    private final VoucherWorkflowEngine workflowEngine;
    private final JwtUtil jwtUtil;


    /**
     * Triggers the async approval/rejection process using Oracle Parallel execution.
     */
    @PostMapping("/process-bulk")
    public ResponseEntity<Map<String, Object>> processBulkRequests(
            @RequestHeader("Authorization") String token,
            @Valid @RequestBody BulkProcessVoucherPostingDto dto) {

        String userId = jwtUtil.getUserIdFromToken(token);
        Integer userRole = jwtUtil.getUserRoleFromToken(token);
        log.info("BULK_PROCESS_START | User: {} | Batch: {} | Action: {}", userId, dto.getBatchId(), dto.getStatus());

        commandService.processBulkRequestsAsync(dto, userId, userRole);

        return ResponseEntity.status(HttpStatus.ACCEPTED).body(Map.of(
                "status", "PROCESSING", "message", "Approval process started. Notifications will be sent upon completion."));
    }


    @PostMapping("/workflow/action")
    public ResponseEntity<Map<String, String>> processCheckerAction(
            @RequestHeader("Authorization") String token,
            @Valid @RequestBody ProcessVoucherRequestDto dto) {

        String userId = jwtUtil.getUserIdFromToken(token);
        Integer userRole = jwtUtil.getUserRoleFromToken(token);

        workflowEngine.processWorkflowAction(dto, userId, userRole);

        return ResponseEntity.ok(Map.of("status", "SUCCESS", "message", "Workflow action processed successfully."));
    }




    // ==================================================================================
    // 1. ASYNC BULK OPERATIONS
    // ==================================================================================

    /**
     * Creates a batch from pre-validated cache data.
     * Uses fire-and-forget logic; returns 202 Accepted immediately.
     */
    @PostMapping("/create-batch-from-cache")
    public ResponseEntity<Map<String, Object>> createBatchFromCache(
            @Valid @RequestBody CacheBatchPostingDto payload,
            @RequestHeader("Authorization") String token) throws IOException {

        String userId = jwtUtil.getUserIdFromToken(token);
        Integer userRole = jwtUtil.getUserRoleFromToken(token);
        log.info("CACHE_BATCH_INIT | User: {} | ReqID: {}", userId, payload.getRequestId());

        String batchId = commandService.createBatchFromCacheAsync(payload.getRequestId(), payload.getCommonBatchRemarks(), userId, userRole, payload.getVid());


        return ResponseEntity.status(HttpStatus.ACCEPTED).body(Map.of(
                "status", "PROCESSING", "message", "Batch creation initiated in background.", "batchId", batchId));
    }


    @PostMapping("/update-schedule")
    public ResponseEntity<Map<String, String>> updateSchedule(@RequestBody Map<String, String> payload) {
        commandService.updateBatchSchedule(payload.get("batchId"), payload.get("scheduledTime"));

        Map<String, String> response = new HashMap<>();
        response.put("message", "Schedule updated successfully.");
        response.put("status", "SUCCESS");
        return ResponseEntity.ok(response);
    }


    // ==================================================================================
    // 5. MANUAL/SMALL BATCH ENDPOINTS
    // ==================================================================================

    @PostMapping("/create-batch")
    public ResponseEntity<List<JournalRequest>> createBatchRequest(
            @Valid @RequestBody BatchPostingDto batchDto,
            @RequestHeader("Authorization") String token) {
        try {
            String userId = jwtUtil.getUserIdFromToken(token);
            log.info("MANUAL_BATCH_CREATE | User: {} | Rows: {}", userId, batchDto.getRows().size());

            List<JournalRequest> created = commandService.createBatchRequest(
                    batchDto, userId, jwtUtil.getUserRoleFromToken(token));
            return ResponseEntity.status(HttpStatus.CREATED).body(created);
        } catch (CustomExceptions.DataMappingException e) {
            log.error("MANUAL_BATCH_JSON_FAIL | Status: Payload serialization error");
            throw new CustomExceptions.DataMappingException("Request contains invalid data format.");
        }
    }


    @DeleteMapping("/my-requests/by-batch/{batchId}")
    public ResponseEntity<ApiResponseDto> deletePendingBatch(@PathVariable String batchId, @RequestHeader("Authorization") String token) {
        try {
            commandService.deleteBatchRequest(batchId, jwtUtil.getUserIdFromToken(token.substring(7)));
            return ResponseEntity.ok(new ApiResponseDto("Success", "Batch deletion process initiated.", null));
        } catch (IllegalStateException e) {
            return ResponseEntity.status(HttpStatus.FORBIDDEN).body(new ApiResponseDto("Error", e.getMessage(), null));
        } catch (CustomExceptions.InvalidDataException e) {
            // FIX: Catch specific business errors and send the exact message to React
            return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ApiResponseDto("Error", e.getMessage(), null));
        } catch (Exception e) {
            log.error("BATCH_DELETE_FAIL | Batch: {} | Error: {}", batchId, e.getMessage());
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new ApiResponseDto("Error", "An unexpected error occurred.", null));
        }
    }


    @DeleteMapping("/my-request/{requestId}")
    public ResponseEntity<Void> cancelMyRequest(@RequestHeader("Authorization") String token, @PathVariable Long requestId) {
        commandService.cancelMyRequest(requestId, jwtUtil.getUserIdFromToken(token));
        return ResponseEntity.noContent().build();
    }
}


package com.fincore.VoucherService.Controllers;


import com.fincore.VoucherService.Dto.BulkUploadStateDto;
import com.fincore.VoucherService.Exception.CustomExceptions;
import com.fincore.VoucherService.Service.validation.ValidationReportGenerator;
import com.fincore.VoucherService.Service.validation.VoucherBulkValidationService;
import jakarta.servlet.http.HttpServletRequest;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.core.io.ByteArrayResource;
import org.springframework.core.io.Resource;
import org.springframework.format.annotation.DateTimeFormat;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.time.LocalDate;
import java.util.Map;

@RestController
@RequestMapping("/api/voucher")
@RequiredArgsConstructor
@Slf4j
public class VoucherBulkUploadController {

    private final VoucherBulkValidationService voucherBulkValidationService;
    private final ValidationReportGenerator validationReportGenerator;
    /**
     * Entry point for Journal File uploads. Validates file existence and starts parsing.
     */

    @PostMapping(value = "/bulk-validate-init", consumes = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<Map<String, Object>> initiateValidation(
            @RequestParam("file") MultipartFile file,
            @RequestParam("postingDate") @DateTimeFormat(pattern = "dd/MM/yyyy") LocalDate postingDate,
            HttpServletRequest request) {

        if (file == null || file.isEmpty()) {
            return ResponseEntity.status(org.springframework.http.HttpStatus.BAD_REQUEST)
                    .body(Map.of("message", "File is missing or empty."));
        }

        try {
            String reqId = voucherBulkValidationService.initiateValidation(file, postingDate);

            HttpHeaders headers = new HttpHeaders();
            headers.setCacheControl(org.springframework.http.CacheControl.noCache().mustRevalidate().sMaxAge(java.time.Duration.ZERO));
            headers.setPragma("no-cache");
            headers.setExpires(0L);
            headers.set("X-Content-Type-Options", "nosniff");
            headers.set("Content-Security-Policy", "default-src 'self'");

            return ResponseEntity.ok()
                    .headers(headers)
                    .body(Map.of("status", "QUEUED", "requestId", reqId));

        } catch (CustomExceptions.FileProcessingException e) {
            // FIX: Explicitly catch our custom validation errors and send the EXACT message back to React
            return ResponseEntity.status(org.springframework.http.HttpStatus.BAD_REQUEST)
                    .body(Map.of("message", e.getMessage()));

        } catch (Exception e) {
            // Fallback for unexpected system errors
            log.error("VALIDATION_INIT_FAIL | File: {} | Error: {}", file.getOriginalFilename(), e.getMessage());
            return ResponseEntity.status(org.springframework.http.HttpStatus.INTERNAL_SERVER_ERROR)
                    .body(Map.of("message", "An unexpected error occurred during upload."));
        }
    }


    @GetMapping("/bulk-status/{requestId}")
    public ResponseEntity<BulkUploadStateDto> checkStatus(@PathVariable String requestId) {
        BulkUploadStateDto state = voucherBulkValidationService.getState(requestId);
        return state != null ? ResponseEntity.ok(state) : ResponseEntity.notFound().build();
    }


    /**
     * Downloads the error report excel file.
     */
    @GetMapping("/download-bulk-file/{requestId}")
    public ResponseEntity<Resource> downloadFile(@PathVariable String requestId, @RequestParam String type) {
        byte[] data = voucherBulkValidationService.getFileBytes(requestId, type);
        if (data == null) {
            log.warn("DOWNLOAD_FAIL | File not found | ReqID: {} | Type: {}", requestId, type);
            return ResponseEntity.notFound().build();
        }

        // Retrieves the strict date format (e.g., "2026-06-18") without timestamps
        String filename = "Error_Report" + ".xlsx";


        // Exclusively sets the MIME type to Excel (.xlsx) since CSV is no longer needed
        MediaType mediaType = MediaType.parseMediaType("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

        return ResponseEntity.ok()
                .header(HttpHeaders.CONTENT_DISPOSITION, "attachment; filename=\"" + filename + "\"")
                .contentType(mediaType)
                .body(new ByteArrayResource(data));
    }

    @GetMapping("/download-template")
    public ResponseEntity<org.springframework.core.io.Resource> downloadTemplate() throws IOException {
        return ResponseEntity.ok().header(HttpHeaders.CONTENT_DISPOSITION, "attachment; filename=\"Voucher_Template.xlsx\"").body(new ByteArrayResource(validationReportGenerator.generateExcelTemplateWithGuidelines()));
    }

}


