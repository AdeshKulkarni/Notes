        activeStep === 2 && entryMethod === "BULK" && (
          <JournalBulkUpload
            selectedVoucher={selectedVoucher}
            onBack={handleBack}
            onReset={handleResetWizard}
            // Triggered automatically when Bulk Excel completes
            onSuccessSubmit={(batchId) => {
              setSubmittedBatchId(batchId);
              setActiveStep(3);
            }}
          />
        )
      }

      {/* NEW STEP 3: POST-SUBMISSION SUCCESS & SCHEDULING SCREEN */}
      {
        activeStep === 3 && (
          <Box sx={{ p: 4, display: 'flex', justifyContent: 'center' }}>
            <Paper elevation={3} sx={{ p: 4, borderRadius: 3, maxWidth: 650, width: '100%', textAlign: 'center' }}>
              <Typography variant="h6" fontWeight="bold" color="text.primary" gutterBottom>
                Set Execution Preference
              </Typography>
              <Typography variant="h5" fontWeight="bold" gutterBottom>
                Your batch is validated and ready to submit.
              </Typography>

              <Divider sx={{ my: 3 }} />


              <Typography variant="body2" color="text.secondary" sx={{ mb: 4 }}>
                Please select how you want this batch to be executed after the final approval.
              </Typography>

              {/* SELECTION CARDS */}
              <Grid container spacing={3} sx={{ mb: 4, textAlign: 'left' }}>
                <Grid item xs={12} sm={6}>
                  <Box
                    onClick={() => setRoutingChoice("IMMEDIATE")}
                    sx={{
                      p: 2.5, border: "2px solid", borderRadius: 2, cursor: "pointer", transition: "all 0.2s ease",
                      borderColor: routingChoice === "IMMEDIATE" ? "primary.main" : "divider",
                      backgroundColor: routingChoice === "IMMEDIATE" ? "primary.50" : "transparent",
                      display: "flex", flexDirection: "column", alignItems: "center", gap: 1, textAlign: "center",
                      "&:hover": { borderColor: routingChoice !== "IMMEDIATE" ? "primary.light" : "primary.main", transform: "translateY(-2px)", boxShadow: 2 }
                    }}
                  >
                    <BoltIcon color={routingChoice === "IMMEDIATE" ? "primary" : "action"} sx={{ fontSize: 36 }} />
                    <Typography variant="subtitle1" fontWeight="bold" color={routingChoice === "IMMEDIATE" ? "primary.main" : "text.primary"}>
                      Execute Immediately
                    </Typography>
                    <Typography variant="caption" color="text.secondary">
                      Post automatically upon final approval
                    </Typography>
                  </Box>
                </Grid>

                <Grid item xs={12} sm={6}>
                  <Box
                    onClick={() => {
                      setRoutingChoice("SCHEDULE");
                      setScheduledTime(dayjs().add(35, 'minute').second(0).millisecond(0));
                    }}
                    sx={{
                      p: 2.5, border: "2px solid", borderRadius: 2, cursor: "pointer", transition: "all 0.2s ease",
                      borderColor: routingChoice === "SCHEDULE" ? "primary.main" : "divider",
                      backgroundColor: routingChoice === "SCHEDULE" ? "primary.50" : "transparent",
                      display: "flex", flexDirection: "column", alignItems: "center", gap: 1, textAlign: "center",
                      "&:hover": { borderColor: routingChoice !== "SCHEDULE" ? "primary.light" : "primary.main", transform: "translateY(-2px)", boxShadow: 2 }
                    }}
                  >
                    <ScheduleIcon color={routingChoice === "SCHEDULE" ? "primary" : "action"} sx={{ fontSize: 36 }} />
                    <Typography variant="subtitle1" fontWeight="bold" color={routingChoice === "SCHEDULE" ? "primary.main" : "text.primary"}>
                      Schedule Execution
                    </Typography>
                    <Typography variant="caption" color="text.secondary">
                      Delay posting to a future time today
                    </Typography>
                  </Box>
                </Grid>
              </Grid>

              {/* SMOOTH COLLAPSE FOR TIMEPICKER */}
              <Collapse in={routingChoice === "SCHEDULE"}>
                <Box sx={{ p: 3, mb: 4, border: '1px solid', borderColor: 'divider', borderRadius: 2 }}>
                  <Typography variant="subtitle2" fontWeight="bold" align="left" gutterBottom>
                    Select Time
                  </Typography>
                  <LocalizationProvider dateAdapter={AdapterDayjs}>
                    <TimePicker
                      value={scheduledTime}
                      onChange={(newValue) => setScheduledTime(newValue)}
                      minTime={dayjs().add(30, 'minute')}
                      maxTime={dayjs().endOf('day')}
                      timeSteps={{ minutes: 1 }}
                      slotProps={{
                        textField: {
                          size: 'medium',
                          fullWidth: true,
                          sx: { caretColor: 'transparent' },
                          // FIX: Change 30 to 31 in the text below
                          helperText: "Execution must be scheduled at least 31 mins from now, and before 11:59 PM today.",
                          onKeyDown: (e) => e.preventDefault(),
                          onPaste: (e) => e.preventDefault(),
                          inputProps: { readOnly: true }
                        }
                      }}
                    />
                  </LocalizationProvider>
                </Box>
              </Collapse>

              {/* FINAL SUBMIT BUTTON */}
              <Button
                variant="contained"
                size="large"
                fullWidth
                disabled={!routingChoice || (routingChoice === 'SCHEDULE' && !scheduledTime) || isFinalizing}
                onClick={handleFinalizeRouting}
                sx={{ py: 1.5, fontSize: '1.1rem', fontWeight: 'bold', borderRadius: 2 }}
              >
                {isFinalizing ? <CircularProgress size={28} color="inherit" /> : "Submit"}
              </Button>

            </Paper>
          </Box>
        )
      }

    </Paper >

  );
}
