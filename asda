    public List<Map<String, Object>> getWorkflowSteps(String workflowCode) {
        return jdbcTemplate.query("SELECT w.WORKFLOW_STAGE AS state, w.WORKFLOW_STAGE AS designation, w.ALLOWED_ROLE_ID AS role_id, r.ROLE_NAME FROM WORKFLOW_TRANSITIONS w LEFT JOIN ROLES r ON w.ALLOWED_ROLE_ID = r.ROLE_ID WHERE w.WORKFLOW_CODE = ? ORDER BY w.WORKFLOW_ORDER ASC", (rs, rowNum) -> {
            Map<String, Object> step = new HashMap<>(); step.put("state", rs.getString("state")); step.put("designation", rs.getString("designation"));
            step.put("role", rs.getString("ROLE_NAME") != null ? rs.getString("ROLE_NAME") : "System"); return step;
        }, workflowCode);
    }

    public Map<String, String> getActiveRoles() {
        return jdbcTemplate.query("SELECT ROLE_ID, ROLE_NAME FROM ROLES WHERE ROLE_STATUS = 'ACTIVE'", rs -> {
            Map<String, String> roleMap = new HashMap<>();
            while (rs.next()) { roleMap.put(String.valueOf(rs.getLong("ROLE_ID")), rs.getString("ROLE_NAME")); } return roleMap;
        });
    }

    public Map<String, Object> getVidDetails(String vid) {
        try { return jdbcTemplate.queryForMap("SELECT r.VID, r.DESCRIPTION, r.CREATED_BY, r.CREATED_AT, r.REMARKS, c.CATEGORY_NAME FROM REQUEST_VOUCHER r LEFT JOIN VOUCHER_CATEGORY c ON r.CATEGORY_ID = c.ID WHERE r.VID = ?", vid); }
        catch (EmptyResultDataAccessException e) { return new HashMap<>(); }
    }

    public List<Map<String, Object>> getAvailableVouchersVid(Long roleId) {
        // Step 1: Fetch the core voucher data (No inline subquery to avoid Oracle null stripping)
        String sql = """
            SELECT 
                rv.ID,
                rv.VID,
                rv.DESCRIPTION,
                c.CATEGORY_NAME,
                rv.CREATED_BY AS CREATOR_ID,
                COALESCE(u.FIRST_NAME || ' ' || u.LAST_NAME, rv.CREATED_BY) AS CREATOR_NAME,
                rv.CREATED_AT
            FROM REQUEST_VOUCHER rv
            LEFT JOIN VOUCHER_CATEGORY c ON rv.CATEGORY_ID = c.ID
            LEFT JOIN USERS u ON rv.CREATED_BY = u.USER_ID
            WHERE rv.ALLOWED_ROLE = ? AND rv.STATUS = 'ACTIVE'
            ORDER BY rv.CREATED_AT DESC
        """;

        List<Map<String, Object>> vouchers = jdbcTemplate.query(sql, (rs, rowNum) -> {
            Map<String, Object> map = new HashMap<>();
            map.put("id", rs.getLong("ID"));
            map.put("vid", rs.getString("VID"));
            map.put("description", rs.getString("DESCRIPTION"));
            map.put("categoryName", rs.getString("CATEGORY_NAME"));
            map.put("createdBy", rs.getString("CREATOR_ID"));
            map.put("createdByName", rs.getString("CREATOR_NAME"));

            java.sql.Timestamp ts = rs.getTimestamp("CREATED_AT");
            map.put("createdAt", ts != null ? ts.toInstant().toString() : null);
            return map;
        }, roleId);

        if (vouchers.isEmpty()) {
            return vouchers;
        }

        // Step 2: Fetch the Issue Categories for these specific Vouchers
        List<Long> voucherIds = vouchers.stream()
                .map(v -> (Long) v.get("id"))
                .toList();

        // Dynamically build the IN clause (?,?,?)
        String inClause = String.join(",", Collections.nCopies(voucherIds.size(), "?"));

        String issueSql = String.format("""
            SELECT 
                rvic.REQUEST_VOUCHER_ID, 
                LISTAGG(ic.ISSUE_CATEGORY_NAME, ', ') WITHIN GROUP (ORDER BY ic.ISSUE_CATEGORY_NAME) AS CATEGORIES
            FROM REQUEST_VOUCHER_ISSUE_CATEGORY rvic
            JOIN ISSUE_CATEGORY ic ON rvic.ISSUE_CATEGORY_ID = ic.ID
            WHERE rvic.REQUEST_VOUCHER_ID IN (%s)
            GROUP BY rvic.REQUEST_VOUCHER_ID
        """, inClause);

        Map<Long, String> issueCategoryMap = new HashMap<>();
        jdbcTemplate.query(issueSql, rs -> {
            issueCategoryMap.put(rs.getLong("REQUEST_VOUCHER_ID"), rs.getString("CATEGORIES"));
        }, voucherIds.toArray());

        // Step 3: Map the categories back to the vouchers (Defaults to "N/A" so Jackson never drops the key)
        for (Map<String, Object> voucher : vouchers) {
            Long vId = (Long) voucher.get("id");
            voucher.put("issueCategories", issueCategoryMap.getOrDefault(vId, "N/A"));
        }

        return vouchers;
    }

    public boolean isUserAuthorizedForBatch(String batchId, String userId, Integer roleId) {
        Integer isCreator = jdbcTemplate.queryForObject("SELECT COUNT(*) FROM VOUCHER_POSTING WHERE BATCH_ID = ? AND CREATED_BY = ?", Integer.class, batchId, userId);
        if (isCreator != null && isCreator > 0) return true;
        Integer isAuthorized = jdbcTemplate.queryForObject("SELECT COUNT(*) FROM VOUCHER_POSTING vp JOIN WORKFLOW_TRANSITIONS wt ON vp.PENDING_AT = wt.WORKFLOW_ID WHERE vp.BATCH_ID = ? AND wt.ALLOWED_ROLE_ID = ?", Integer.class, batchId, roleId);
        return isAuthorized != null && isAuthorized > 0;
    }

    public byte[] generateBatchExcel(String batchId) {
        List<JournalRequest> requests = journalRequestRepository.findByBatchId(batchId);
        if (requests == null || requests.isEmpty()) throw new CustomExceptions.InvalidDataException("No records found for batch.");

        try (org.apache.poi.xssf.usermodel.XSSFWorkbook workbook = new org.apache.poi.xssf.usermodel.XSSFWorkbook();
             java.io.ByteArrayOutputStream out = new java.io.ByteArrayOutputStream()) {
            org.apache.poi.ss.usermodel.Sheet sheet = workbook.createSheet("Batch Details");
            org.apache.poi.ss.usermodel.Row headerRow = sheet.createRow(0);
            String[] headers = {"Branch", "Currency", "CGL", "Amount", "Type", "Remarks", "Product Code"};
            for (int i = 0; i < headers.length; i++) headerRow.createCell(i).setCellValue(headers[i]);

            int rowIdx = 1;
            for (JournalRequest req : requests) {
                org.apache.poi.ss.usermodel.Row row = sheet.createRow(rowIdx++);
                row.createCell(0).setCellValue(req.getBranchCode() != null ? req.getBranchCode() : "");
                row.createCell(1).setCellValue(req.getCurrency() != null ? req.getCurrency() : "");
                row.createCell(2).setCellValue(req.getCgl() != null ? req.getCgl() : "");
                if (req.getAmount() != null) {
                    row.createCell(3).setCellValue(req.getAmount().abs().stripTrailingZeros().toPlainString());
                    row.createCell(4).setCellValue(req.getAmount().compareTo(BigDecimal.ZERO) < 0 ? "Credit" : "Debit");
                }
                row.createCell(5).setCellValue(req.getNarration() != null ? req.getNarration() : ""); // Moved Remarks (Narration) to Index 5
                row.createCell(6).setCellValue(req.getProductCode() != null ? req.getProductCode() : ""); // Moved Product Code to Index 6
            }
            workbook.write(out); return out.toByteArray();
        } catch (java.io.IOException e) { throw new CustomExceptions.DatabaseOperationException("Failed to generate Excel file", e); }
    }
}



package com.fincore.VoucherService.Service.core;


import com.fincore.VoucherService.Dto.BulkProcessVoucherPostingDto;
import com.fincore.VoucherService.Dto.ProcessVoucherRequestDto;
import com.fincore.VoucherService.Exception.CustomExceptions;
import com.fincore.VoucherService.Models.VoucherPosting;
import com.fincore.VoucherService.Models.VoucherWorkflow;
import com.fincore.VoucherService.Models.enums.RequestStatus;
import com.fincore.VoucherService.Models.enums.VoucherStatus;
import com.fincore.VoucherService.Repository.VoucherPostingRepository;
import com.fincore.VoucherService.Repository.VoucherWorkflowRepository;
import com.fincore.VoucherService.Service.NotificationWriterService;
import lombok.RequiredArgsConstructor;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.context.annotation.Lazy;
import org.springframework.dao.EmptyResultDataAccessException;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Map;

@Service
@RequiredArgsConstructor
public class VoucherWorkflowEngine {

    @Autowired
    @Qualifier("oracleJdbcTemplate")
    private JdbcTemplate jdbcTemplate;

    private final VoucherPostingRepository voucherPostingRepository;
    private final VoucherWorkflowRepository voucherWorkflowRepository;
    private final NotificationWriterService notificationWriterService;

    // Inject the command service to trigger async execution after final approval
    @Lazy
    @Autowired
    private VoucherCommandService commandService;



    @Transactional
    public void processWorkflowAction(ProcessVoucherRequestDto dto, String executorId, Integer executorRole) {
        String batchId = dto.getBatchId();

        // --- STRICT ACTION REMARKS ENFORCEMENT ---
        if (dto.getRemarks() == null || dto.getRemarks().trim().length() < 2 || dto.getRemarks().trim().length() > 30) {
            throw new CustomExceptions.InvalidDataException("Action remarks are mandatory and must be between 2 and 30 alphanumeric characters.");
        }
        String sanitizedRemarks = dto.getRemarks().replaceAll("[^a-zA-Z0-9 ]", "").trim().replaceAll("\\s{2,}", " ");
        dto.setRemarks(sanitizedRemarks);

        // 1. Unified Fetch: NOW INCLUDES REQUEST_VOUCHER TO GET VID_CREATOR
        Map<String, Object> stepData;
        try {
            stepData = jdbcTemplate.queryForMap("""
                SELECT 
                    p.CREATED_BY AS BATCH_CREATOR, p.VID_FK, p.IS_EXECUTION_SCHEDULED, p.SCHEDULED_TIME,
                    w.WORKFLOW_CODE, w.WORKFLOW_ORDER, w.IS_FINAL_APPROVAL, 
                    w.WORKFLOW_STAGE, w.ALLOWED_ROLE_ID, w.WORKFLOW_ID,
                    rv.CREATED_BY AS VID_CREATOR
                FROM VOUCHER_POSTING p
                JOIN WORKFLOW_TRANSITIONS w ON p.PENDING_AT = w.WORKFLOW_ID
                LEFT JOIN REQUEST_VOUCHER rv ON p.VID_FK = rv.VID
                WHERE p.BATCH_ID = ?
                """, batchId);
        } catch (EmptyResultDataAccessException e) {
            throw new CustomExceptions.InvalidDataException("Batch ID not found or workflow stage invalid.");
        }

        // --- FIX: DECLARE THE VARIABLES HERE ---
        String batchCreatorId = (String) stepData.get("BATCH_CREATOR");
        String vidCreatorId = (String) stepData.get("VID_CREATOR");
        String vid = (String) stepData.get("VID_FK");

        // 2. Security & Authorization Checks
        if (executorId.equalsIgnoreCase(batchCreatorId)) {
            throw new CustomExceptions.InvalidDataException("Security Violation: You cannot approve your own batch.");
        }

        boolean hasAlreadyApproved = voucherWorkflowRepository.findByBatchIdFkOrderByLastActionAtAsc(batchId)
                .stream().anyMatch(w -> executorId.equalsIgnoreCase(w.getLastActionBy()));
        if (hasAlreadyApproved) {
            throw new CustomExceptions.InvalidDataException("Security Violation: You have already approved this batch.");
        }

        Integer allowedRoleId = ((Number) stepData.get("ALLOWED_ROLE_ID")).intValue();
        if (!allowedRoleId.equals(executorRole)) {
            throw new CustomExceptions.InvalidDataException("Unauthorized: Role mismatch.");
        }

        // 3. Variables for Logic
        String workflowCode = (String) stepData.get("WORKFLOW_CODE");
        Integer currentOrder = ((Number) stepData.get("WORKFLOW_ORDER")).intValue();
        String currentStageName = (String) stepData.get("WORKFLOW_STAGE");
        boolean isFinalStep = "Y".equalsIgnoreCase((String) stepData.get("IS_FINAL_APPROVAL"));

        VoucherPosting posting = voucherPostingRepository.findById(batchId).orElseThrow();

        // 4. Handle REJECTION
        if ("REJECTED".equals(dto.getStatus().toString())) {
            posting.setBatchStatus("R");
            voucherPostingRepository.save(posting);

            logWorkflowAction(batchId, vid, "Rejected (" + currentStageName + ")", executorId, dto.getRemarks(), null);

            // FIX: Use VOUCHER_POSTING and VOUCHER_POSTING_DATA for rejections
            jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'REJECTED' WHERE BATCH_ID = ?", batchId);
            jdbcTemplate.update("UPDATE VOUCHER_POSTING_DATA SET REQ_STATUS = 'R', EXECUTION_DATE = SYSTIMESTAMP WHERE BATCH_ID = ?", batchId);

            // Grabs everyone who ever took an action on this batch, excluding the current rejector
            String previousActorsSql = "SELECT DISTINCT LAST_ACTION_BY FROM VOUCHER_WORKFLOW WHERE BATCH_ID_FK = ? AND LAST_ACTION_BY != ?";
            List<String> previousActors = jdbcTemplate.queryForList(previousActorsSql, String.class, batchId, executorId);

            // Failsafe: Ensure the original creators are in the blast list
            if (!previousActors.contains(batchCreatorId)) {
                previousActors.add(batchCreatorId);
            }
            if (vidCreatorId != null && !previousActors.contains(vidCreatorId)) {
                previousActors.add(vidCreatorId);
            }

            // Fire the notifications
            notificationWriterService.createBatchRejectedNotificationForUsers(batchId, previousActors, executorId, dto.getRemarks());

            if (posting.getVidFk() != null && !posting.getVidFk().isEmpty()) updateVidStatus(posting.getVidFk(), VoucherStatus.ACTIVE);
            return;
        }

        // 5. Handle APPROVAL / PROGRESSION
        if (isFinalStep) {
            // Move to Execution Step (Order + 1)
            Long execStepId = jdbcTemplate.queryForObject("SELECT WORKFLOW_ID FROM WORKFLOW_TRANSITIONS WHERE WORKFLOW_CODE = ? AND WORKFLOW_ORDER = ?", Long.class, workflowCode, currentOrder + 1);
            posting.setPendingAt(execStepId);

            boolean isOverride = Boolean.TRUE.equals(dto.getOverrideScheduleLapse());
            if (isOverride) {

                if (dto.getNewScheduledTime() != null) {
                    validateScheduledTime(dto.getNewScheduledTime());
                }

                posting.setIsScheduleOverride("YES");
                posting.setIS_EXECUTION_SCHEDULED(dto.getNewScheduledTime() != null ? "YES" : "NO");
                posting.setScheduledTime(dto.getNewScheduledTime());
            }
            else if ("YES".equalsIgnoreCase(posting.getIS_EXECUTION_SCHEDULED()) && posting.getScheduledTime() != null) {
                if (posting.getScheduledTime().isBefore(LocalDateTime.now())) {
                    throw new CustomExceptions.ScheduleLapsedException("The scheduled execution time has passed.");
                }
                else {
                    posting.setIsScheduleOverride("NO"); // Ensure it stays NO if not triggered
                }
            }

            if ("YES".equalsIgnoreCase(posting.getIS_EXECUTION_SCHEDULED()) && posting.getScheduledTime() != null && posting.getScheduledTime().isAfter(LocalDateTime.now())) {
                posting.setBatchStatus("P");

                String actionLog = isOverride ? "Final Approval(Sch. Override)" : "Final Approval(Scheduled)";
                logWorkflowAction(batchId, vid, actionLog, executorId, dto.getRemarks(), posting.getScheduledTime());

                // FIX: Update VOUCHER_POSTING
                jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'P' WHERE BATCH_ID = ?", batchId);
            } else {
                posting.setBatchStatus("C");
                posting.setExecutedAt(LocalDateTime.now());
                String actionLog = isOverride ? "Final Approval(Imm. Override)" : "Final Approval(Posted)";
                logWorkflowAction(batchId, vid, actionLog, executorId, dto.getRemarks(), null);

                if (posting.getVidFk() != null && !posting.getVidFk().isEmpty()) updateVidStatus(posting.getVidFk(), VoucherStatus.COMPLETED);

                BulkProcessVoucherPostingDto execDto = new BulkProcessVoucherPostingDto();
                execDto.setBatchId(batchId); execDto.setStatus(RequestStatus.ACCEPTED); execDto.setRemarks(dto.getRemarks());
                commandService.processBulkRequestsAsync(execDto, executorId, executorRole);
            }
            // --- NOTIFY BOTH CREATORS OF FINAL APPROVAL ---
            notificationWriterService.createBatchUpdateNotificationForCreators(
                    batchId, vid, batchCreatorId, vidCreatorId, "fully APPROVED", executorId
            );
        } else {
            // --- PERFECTED JOIN LOGIC ---
            // Joins VOUCHER_POSTING with WORKFLOW_TRANSITIONS to safely fetch the exact next routing stage
            String nextStepSql = """
                SELECT w_next.WORKFLOW_ID, w_next.ALLOWED_ROLE_ID
                FROM VOUCHER_POSTING vp
                JOIN WORKFLOW_TRANSITIONS w_curr 
                  ON vp.PENDING_AT = w_curr.WORKFLOW_ID
                JOIN WORKFLOW_TRANSITIONS w_next 
                  ON w_curr.WORKFLOW_CODE = w_next.WORKFLOW_CODE 
                 AND w_next.WORKFLOW_ORDER = (w_curr.WORKFLOW_ORDER + 1)
                WHERE vp.BATCH_ID = ?
            """;

            Map<String, Object> nextStepInfo = jdbcTemplate.queryForMap(nextStepSql, batchId);
            Long nextStepId = ((Number) nextStepInfo.get("WORKFLOW_ID")).longValue();
            String nextRoleId = String.valueOf(nextStepInfo.get("ALLOWED_ROLE_ID"));

            posting.setPendingAt(nextStepId);
            logWorkflowAction(batchId, vid, "Approved (" + currentStageName + ")", executorId, dto.getRemarks(), null);

            // Notifies strictly using the TARGET_ROLE (USER_ID is safely null)
            notificationWriterService.createNextStepApprovalNotification(batchId, nextRoleId);

            // --- NOTIFY BOTH CREATORS OF INTERMEDIATE PROGRESS ---
            notificationWriterService.createBatchUpdateNotificationForCreators(
                    batchId, vid, batchCreatorId, vidCreatorId, "Approved (" + currentStageName + ")", executorId
            );
        }

        voucherPostingRepository.save(posting);
    }


    public void logWorkflowAction(String batchId, String vid, String action, String executorId, String remarks, LocalDateTime scheduledTime) {
        VoucherWorkflow wf = new VoucherWorkflow();
        wf.setBatchIdFk(batchId);
        wf.setVidFk(vid != null ? vid : "UNKNOWN");
        wf.setLastAction(action != null && action.length() > 30 ? action.substring(0, 30) : action);
        wf.setLastActionBy(executorId);
        wf.setLastActionAt(LocalDateTime.now());
        wf.setRemarks(remarks);
        wf.setScheduledTime(scheduledTime);
        voucherWorkflowRepository.save(wf);
    }

    public void validateScheduledTime(LocalDateTime scheduledTime) {
        if (scheduledTime == null) return;
        LocalDateTime minTime = LocalDateTime.now().plusMinutes(28);
        LocalDateTime maxTime = LocalDateTime.now().with(java.time.LocalTime.MAX);

        if (scheduledTime.isBefore(minTime)) {
            throw new CustomExceptions.InvalidDataException("Scheduled time must be at least 30 minutes from the current time.");
        }
        if (scheduledTime.isAfter(maxTime)) {
            throw new CustomExceptions.InvalidDataException("Scheduled time cannot exceed today's end of day (11:59 PM).");
        }
    }

    public void updateVidStatus(String vid, VoucherStatus status) {
        String sql = "UPDATE REQUEST_VOUCHER SET STATUS = ? WHERE VID = ?";
        jdbcTemplate.update(sql, status.name(), vid);
    }

}
package com.fincore.VoucherService.Service.schedule;

import com.fincore.VoucherService.Dto.HdfsSyncDto;
import com.fincore.VoucherService.Exception.CustomExceptions;
import com.fincore.VoucherService.Service.external.HdfsSyncService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.dao.DataAccessException;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class HdfsRecoveryService {

    private final HdfsSyncService hdfsSyncService;
    @Autowired
    @Qualifier("oracleJdbcTemplate")
    private JdbcTemplate oracleJdbcTemplate;

    // Injecting StringRedisTemplate for Distributed Locking
    @Autowired
    private org.springframework.data.redis.core.StringRedisTemplate stringRedisTemplate;

    /**
     * Scheduled task to retry PENDING syncs from the retry queue.
     * Runs every 5 minutes with fixed delay to prevent overlapping executions.
     */

    @Scheduled(fixedDelay = 300000)
    public void retryFailedHdfsSyncs() {
        String lockKey = "SYSTEM_LOCK_HDFS_RECOVERY";
        boolean lockAcquired = false;

        try {
//            Lock TTL extended to 10 mins to prevent race conditions under load
            Boolean acquired = stringRedisTemplate.opsForValue()
                    .setIfAbsent(lockKey, "LOCKED", 10, java.util.concurrent.TimeUnit.MINUTES);
            lockAcquired = Boolean.TRUE.equals(acquired);

            if (!lockAcquired) {
                log.debug("HDFS_RECOVERY_SKIPPED | Status: Another node is currently processing.");
                return;
            }

            String fetchSql = "SELECT BATCH_ID FROM HDFS_SYNC_RETRY_QUEUE WHERE STATUS = 'PENDING' AND RETRY_COUNT < 5";
            List<String> failedBatches;
            try {
                failedBatches = oracleJdbcTemplate.query(fetchSql, (rs, rowNum) -> rs.getString("BATCH_ID"));
            } catch (DataAccessException e) {
                log.error("HDFS_RECOVERY_QUERY_FAIL | Error: {}", e.getMessage());
                return;
            }

            if (failedBatches.isEmpty()) return;

            log.info("HDFS RECOVERY: Found {} failed batches.", failedBatches.size());
            for (String batchId : failedBatches) {
                try {
                    processRetry(batchId);
                } catch (DataAccessException | CustomExceptions.DatabaseOperationException e) {
                    log.error("HDFS_RECOVERY_ERROR | Batch: {} | Error: {}", batchId, e.getMessage());
                    incrementRetryCount(batchId);
                }
            }
        } catch (org.springframework.data.redis.RedisConnectionFailureException e) {
            log.error("HDFS_RECOVERY_REDIS_FAIL | Cannot acquire distributed lock.");
        } finally {
           // Only release if THIS thread actually acquired it!
            if (lockAcquired) {
                try { stringRedisTemplate.delete(lockKey); }
                catch (Exception e) { log.warn("HDFS_LOCK_RELEASE_FAIL"); }
            }
        }
    }
    /**
     * Performs a fresh join between Journal Requests and GL Balances to push
     * the most current data to HDFS, resolving possible race conditions.
     */
    private void processRetry(String batchId) {
        String freshDataSql = """
            SELECT 
                j.REQ_BRANCH_CODE AS BRANCH, 
                j.REQ_CURRENCY AS CURRENCY, 
                j.REQ_CGL AS CGL, 
                j.REQ_CSV_DATE AS BAL_DATE,
                g.BALANCE AS NEW_BALANCE,
                g.INR_BALANCE AS NEW_INR_BALANCE
            FROM (
                SELECT DISTINCT REQ_BRANCH_CODE, REQ_CURRENCY, REQ_CGL, REQ_CSV_DATE 
                FROM JOURNAL_REQUEST 
                WHERE BATCH_ID = ?
            ) 
            JOIN GL_BALANCE g ON 
                g.BRANCH_CODE = j.REQ_BRANCH_CODE AND 
                g.CURRENCY = j.REQ_CURRENCY AND 
                g.CGL = j.REQ_CGL AND 
                g.BALANCE_DATE = j.REQ_CSV_DATE
        """;

        List<HdfsSyncDto> freshSyncData = oracleJdbcTemplate.query(freshDataSql,
                (rs, rowNum) -> new HdfsSyncDto(
                        rs.getString("BRANCH"),
                        rs.getString("CURRENCY"),
                        rs.getString("CGL"),
                        rs.getDate("BAL_DATE").toLocalDate(),
                        rs.getBigDecimal("NEW_BALANCE"),
                        rs.getBigDecimal("NEW_INR_BALANCE")
                ), batchId);

        if (!freshSyncData.isEmpty()) {

            // 3. Push the LATEST/CURRENT balance to HDFS

            hdfsSyncService.syncToDataLake(freshSyncData);
            log.info("HDFS RECOVERY: Successfully synced batch {}. Data is now consistent.", batchId);
        }

        // 4. Mark as Completed
        oracleJdbcTemplate.update("UPDATE HDFS_SYNC_RETRY_QUEUE SET STATUS = 'COMPLETED' WHERE BATCH_ID = ?", batchId);
    }
    private void incrementRetryCount(String batchId) {
        try {
            oracleJdbcTemplate.update("UPDATE HDFS_SYNC_RETRY_QUEUE SET RETRY_COUNT = RETRY_COUNT + 1 WHERE BATCH_ID = ?", batchId);
        } catch (DataAccessException e) {
            log.error("HDFS_RECOVERY_META_UPDATE_FAIL | Batch: {} | Failed to increment retry count", batchId);
        }
    }
}
package com.fincore.VoucherService.Service.schedule;


import com.fincore.VoucherService.Service.NotificationWriterService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Component;

import java.util.List;
import java.util.Map;

@Component
@RequiredArgsConstructor
@Slf4j
public class VoucherEscalationScheduler {

    private final JdbcTemplate jdbcTemplate;
    private final NotificationWriterService notificationWriterService;

    /**
     * Runs every 1 minute (60,000 milliseconds) in the background.
     * Scans for any pending batches that have breached their designated ESCALATION_TIME.
     */
    @Scheduled(fixedRate = 60000)
    public void checkAndTriggerEscalations() {

        // --- THE ESCALATION QUERY ---
        // 1. Finds 'Pending' batches with an escalation limit > 0
        // 2. Checks if (Last Action Time + Escalation Minutes) is older than RIGHT NOW
        // 3. Ensures we haven't already sent an escalation for this specific stage to prevent spam
        String sql = """
            SELECT 
                vp.BATCH_ID, 
                vp.CREATED_BY, 
                TO_CHAR(wt.ALLOWED_ROLE_ID) AS ROLE_ID, 
                wt.WORKFLOW_STAGE
            FROM VOUCHER_POSTING vp
            JOIN WORKFLOW_TRANSITIONS wt ON vp.PENDING_AT = wt.WORKFLOW_ID
            WHERE vp.BATCH_STATUS = 'P' 
              AND wt.ESCALATION_TIME > 0
              AND (
                    SELECT MAX(LAST_ACTION_AT) 
                    FROM VOUCHER_WORKFLOW 
                    WHERE BATCH_ID_FK = vp.BATCH_ID
                  ) + NUMTODSINTERVAL(wt.ESCALATION_TIME, 'MINUTE') < SYSTIMESTAMP
              AND NOT EXISTS (
                    SELECT 1 FROM NOTIFICATIONS n 
                    WHERE n.AGGREGATE_ID = vp.BATCH_ID 
                      AND n.EVENT_SOURCE = 'EscalationEngine'
                      AND n.MESSAGE LIKE '%' || wt.WORKFLOW_STAGE || '%'
              )
        """;

        try {
            List<Map<String, Object>> breachedBatches = jdbcTemplate.queryForList(sql);

            if (!breachedBatches.isEmpty()) {
                log.warn("ESCALATION_ENGINE | Found {} batches breaching SLA limits.", breachedBatches.size());
            }

            // Loop through the breached batches and fire the notifications
            for (Map<String, Object> batch : breachedBatches) {
                String batchId = (String) batch.get("BATCH_ID");
                String targetRoleId = (String) batch.get("ROLE_ID");
                String stageName = (String) batch.get("WORKFLOW_STAGE");
                String creatorId = (String) batch.get("CREATED_BY");

                notificationWriterService.createEscalationNotification(batchId, targetRoleId, stageName, creatorId);

                log.info("ESCALATION_TRIGGERED | Batch: {} | Stage: {} | Alerted Role: {}", batchId, stageName, targetRoleId);
            }

        } catch (Exception e) {
            log.error("ESCALATION_ENGINE_FAIL | Error running scheduled SLA check: {}", e.getMessage());
        }
    }
}

package com.fincore.VoucherService.Service.schedule;

import com.fincore.VoucherService.Models.enums.RequestStatus;
import com.fincore.VoucherService.Dto.BulkProcessVoucherPostingDto;
import com.fincore.VoucherService.Service.core.VoucherCommandService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.dao.EmptyResultDataAccessException;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Map;
import java.util.concurrent.TimeUnit;

@Service
@RequiredArgsConstructor
@Slf4j
public class VoucherExecutionScheduler {

    private final JdbcTemplate jdbcTemplate;
    private final StringRedisTemplate stringRedisTemplate;
    private final VoucherCommandService voucherCommandService;

    private static final int MAX_RETRIES = 5;

    /**
     * Runs every 60 seconds. Uses a Redis lock to ensure only one pod
     * executes the scheduled batches in a distributed environment.
     */
    @Scheduled(fixedRate = 60000)
    public void executeScheduledBatches() {
        String lockKey = "SYSTEM_LOCK_SCHEDULED_EXECUTION";
        boolean lockAcquired = false;

        try {
            // 1. Distributed lock so only one server pod runs this at a time
            Boolean acquired = stringRedisTemplate.opsForValue()
                    .setIfAbsent(lockKey, "LOCKED", 50, TimeUnit.SECONDS);
            lockAcquired = Boolean.TRUE.equals(acquired);

            if (!lockAcquired) return;

            // --- STEP 1: HOUSEKEEPING (Update success states) ---
            // If the core service successfully processed the batch, it changed the BATCH_STATUS to 'A' or 'C'.
            // We find those and cleanly mark them as COMPLETED in our retry tracker.
            String cleanupSql = """
                UPDATE SCHEDULED_BATCH_RETRY r 
                SET r.STATUS = 'COMPLETED' 
                WHERE r.STATUS = 'PENDING' 
                AND EXISTS (
                    SELECT 1 FROM VOUCHER_POSTING p 
                    WHERE p.BATCH_ID = r.BATCH_ID 
                    AND p.BATCH_STATUS IN ('A', 'C', 'POSTED')
                )
            """;
            jdbcTemplate.update(cleanupSql);

            // --- STEP 2: FETCH DUE BATCHES ---
            String fetchSql = """
                SELECT p.BATCH_ID FROM VOUCHER_POSTING p 
                WHERE p.BATCH_STATUS = 'P' 
                AND p.IS_EXECUTION_SCHEDULED = 'YES' 
                AND p.SCHEDULED_TIME <= ? 
                AND EXISTS (
                    SELECT 1 FROM VOUCHER_WORKFLOW vw 
                    WHERE vw.BATCH_ID_FK = p.BATCH_ID 
                    AND vw.LAST_ACTION LIKE 'Final Approval%'
                )
            """;

            java.sql.Timestamp currentTime = java.sql.Timestamp.valueOf(LocalDateTime.now());
            List<String> dueBatches = jdbcTemplate.queryForList(fetchSql, String.class, currentTime);

            if (dueBatches.isEmpty()) return;

            log.info("SCHEDULER_WAKEUP | Found {} scheduled batches ready for execution.", dueBatches.size());

            // --- STEP 3: PROCESS WITH RETRY TRACKING ---
            for (String batchId : dueBatches) {
                try {
                    int currentRetries = 0;

                    // A. Check tracking table
                    try {
                        Map<String, Object> retryData = jdbcTemplate.queryForMap(
                                "SELECT RETRY_COUNT, STATUS FROM SCHEDULED_BATCH_RETRY WHERE BATCH_ID = ?", batchId);
                        currentRetries = ((Number) retryData.get("RETRY_COUNT")).intValue();
                    } catch (EmptyResultDataAccessException e) {
                        // First attempt: Create tracking record
                        jdbcTemplate.update(
                                "INSERT INTO SCHEDULED_BATCH_RETRY (BATCH_ID, CREATED_AT, RETRY_COUNT, STATUS) VALUES (?, SYSTIMESTAMP, 0, 'PENDING')",
                                batchId);
                    }

                    // B. Validate Limits
                    if (currentRetries >= MAX_RETRIES) {
                        log.error("SCHEDULER_EXHAUSTED | Batch {} failed after {} attempts. Halting execution.", batchId, MAX_RETRIES);

                        // Mark Tracker as FAILED
                        jdbcTemplate.update("UPDATE SCHEDULED_BATCH_RETRY SET STATUS = 'FAILED' WHERE BATCH_ID = ?", batchId);

                        // Mark Master Batch as P so the UI stops showing it as Pending/Scheduled
                        jdbcTemplate.update("UPDATE VOUCHER_POSTING SET BATCH_STATUS = 'P' WHERE BATCH_ID = ?", batchId);
                        continue;
                    }

                    // C. Increment Attempt Count
                    jdbcTemplate.update("UPDATE SCHEDULED_BATCH_RETRY SET RETRY_COUNT = RETRY_COUNT + 1 WHERE BATCH_ID = ?", batchId);

                    // D. Fire the Core Execution
                    BulkProcessVoucherPostingDto execDto = new BulkProcessVoucherPostingDto();
                    execDto.setBatchId(batchId);
                    execDto.setStatus(RequestStatus.ACCEPTED);
                    execDto.setRemarks("Executed automatically by System Scheduler");

                    voucherCommandService.processBulkRequestsAsync(execDto, "SYSTEM", 9001);
                    log.info("SCHEDULER_TRIGGERED | Batch: {} processing started (Attempt {}/{}).", batchId, (currentRetries + 1), MAX_RETRIES);

                } catch (Exception e) {
                    log.error("SCHEDULER_LOOP_FAIL | Batch: {} | Error: {}", batchId, e.getMessage());
                }
            }

        } catch (Exception e) {
            log.error("SCHEDULER_CRITICAL_ERROR | {}", e.getMessage());
        } finally {
            if (lockAcquired) {
                stringRedisTemplate.delete(lockKey);
            }
        }
    }
}

package com.fincore.VoucherService.Service.validation;

import com.fincore.VoucherService.Dto.ExcelRowData;
import com.fincore.VoucherService.Dto.ParsingResult;
import org.apache.poi.ss.usermodel.*;
import org.springframework.stereotype.Service;

import java.io.IOException;
import java.io.InputStream;
import java.math.BigDecimal;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.Pattern;


@Service
public class ExcelStreamingParser {

    private static final Pattern CLEAN_AMOUNT_REGEX = Pattern.compile("[^0-9.]");
    private static final DateTimeFormatter SYSTEM_DATE_FMT = DateTimeFormatter.ofPattern("ddMMyyyy");
    private VoucherBulkValidationService voucherBulkValidationService;


    public ParsingResult parseExcelStream(InputStream is, LocalDate postingDate) throws IOException {
        List<ExcelRowData> list = new ArrayList<>();
        boolean hasProductCol = false;
        DataFormatter fmt = new DataFormatter();

        try (Workbook wb = com.github.pjfanning.xlsx.StreamingReader.builder()
                .rowCacheSize(100)
                .bufferSize(4096)
                .open(is)) {

            Sheet sheet = wb.getSheetAt(0);
            for (Row r : sheet) {
                if (isRowEmpty(r)) continue;

                if (r.getRowNum() == 0) {
                    String h = fmt.formatCellValue(r.getCell(0)).toLowerCase();
                    if (h.contains("branch") || h.contains("batch")) continue;
                }

                ExcelRowData d = new ExcelRowData();
                d.rowIndex = r.getRowNum();
                String col0 = parseCode(r.getCell(0), fmt);

                if (("01".equals(col0) || "1".equals(col0)) && r.getLastCellNum() > 8) {
                    d.isSystemFormat = true;
                    d.sysSite = col0;
                    d.sysDate = parseCode(r.getCell(1), fmt);
                    d.sysYear = parseCode(r.getCell(2), fmt);
                    d.sysPeriod = parseCode(r.getCell(3), fmt);
                    d.branch = padBranch(parseCode(r.getCell(4), fmt));
                    d.currency = fmt.formatCellValue(r.getCell(5)).trim().toUpperCase();
                    d.cgl = parseCode(r.getCell(6), fmt);
                    parseAmount(d, fmt.formatCellValue(r.getCell(7)), fmt.formatCellValue(r.getCell(8)));
                    d.remarks = fmt.formatCellValue(r.getCell(9)).trim();

                    Cell prodCell = r.getCell(10);
                    String rawProd = (prodCell != null) ? parseCode(prodCell, fmt).trim() : "";
                    d.productCode = rawProd;
                    if (!rawProd.isEmpty() && !"A".equalsIgnoreCase(rawProd)) {
                        hasProductCol = true;
                    }

                    validateSystemColumns(d, col0, d.sysDate, d.sysYear, d.sysPeriod,
                            parseCode(r.getCell(11), fmt), parseCode(r.getCell(12), fmt), parseCode(r.getCell(13), fmt), postingDate);
                } else {
                    d.branch = padBranch(col0);
                    d.currency = fmt.formatCellValue(r.getCell(1)).trim().toUpperCase();
                    d.cgl = parseCode(r.getCell(2), fmt);
                    parseAmount(d, fmt.formatCellValue(r.getCell(3)), fmt.formatCellValue(r.getCell(4)));
                    d.remarks = fmt.formatCellValue(r.getCell(5)).trim();

                    Cell prodCell = r.getCell(6);
                    String rawProd = (prodCell != null) ? parseCode(prodCell, fmt).trim() : "";
                    d.productCode = rawProd;
                    if (!rawProd.isEmpty() && !"A".equalsIgnoreCase(rawProd)) {
                        hasProductCol = true;
                    }
                }
                list.add(d);
            }
        } catch (Exception e) {
            throw new IOException("Failed to stream Excel content: " + e.getMessage(), e);
        }

        return new ParsingResult(list, hasProductCol);
    }

    /**
     * Rule 4: Amount parsing logic.
     * Ensures Dr/Cr detection and scale validation without changing numeric values.
     */
    private void parseAmount(ExcelRowData d, String amountRaw, String typeRaw) {
        try {
            String amtClean = (amountRaw == null) ? "" : amountRaw.trim();
            if (amtClean.contains("-") || amtClean.contains("(") || amtClean.contains(")"))
                d.formatErrors.add("Amount cannot be negative");
            String clean = CLEAN_AMOUNT_REGEX.matcher(amtClean).replaceAll("");
            if (clean.isEmpty()) { d.amount = BigDecimal.ZERO; return; }

            BigDecimal v = new BigDecimal(clean);
            if (v.signum() < 0) d.formatErrors.add("Amount cannot be negative");

            d.txnType = (typeRaw != null) ? typeRaw.trim().toUpperCase() : "";
            d.amount = v;
        } catch (NumberFormatException | ArithmeticException e) {
            d.amount = BigDecimal.ZERO;
            d.formatErrors.add("Invalid numeric format");
        }
    }

    private String padBranch(String branch) {
        if (branch == null || branch.trim().isEmpty()) return "";
        String b = branch.trim();
        if (b.length() < 5) {
            return String.format("%5s", b).replace(' ', '0');
        }
        return b;
    }

    private void validateSystemColumns(ExcelRowData d, String c0, String cDate, String cYear, String cMonth, String c11, String c12, String c13, LocalDate postingDate) {
        if (!"01".equals(c0)) d.formatErrors.add("Site must be '01'.");
        try {
            if (cDate == null || cDate.trim().length() != 8) {
                d.formatErrors.add("Invalid date format. Expected: ddMMyyyy.");
            } else {
                LocalDate parsedDate = LocalDate.parse(cDate.trim(), SYSTEM_DATE_FMT);
                if (!parsedDate.equals(postingDate)) d.formatErrors.add("Date does not match the current posting date.");

                String expectedYear = (parsedDate.getMonthValue() >= 4) ? String.valueOf(parsedDate.getYear()) : String.valueOf(parsedDate.getYear() - 1);
                String expectedMonth = String.format("%02d", (parsedDate.getMonthValue() >= 4) ? (parsedDate.getMonthValue() - 3) : (parsedDate.getMonthValue() + 9));
                if (cYear == null || !cYear.trim().equals(expectedYear)) d.formatErrors.add("Invalid financial year. Expected: " + expectedYear);
                if (cMonth == null || !cMonth.trim().equals(expectedMonth)) d.formatErrors.add("Invalid financial month. Expected: " + expectedMonth);
            }
        } catch (DateTimeParseException e) {
            d.formatErrors.add("Invalid calendar date.");
        }

        if (c11 == null || !"B".equalsIgnoreCase(c11.trim())) d.formatErrors.add("Column 12 must be 'B'.");
        if (c12 == null || !"C".equalsIgnoreCase(c12.trim())) d.formatErrors.add("Column 13 must be 'C'.");
        if (c13 == null || !"D".equalsIgnoreCase(c13.trim())) d.formatErrors.add("Column 14 must be 'D'.");
    }

    private String parseCode(Cell c, DataFormatter f) {
        if (c == null) return "";
        if (c.getCellType() == CellType.NUMERIC) return BigDecimal.valueOf(c.getNumericCellValue()).toPlainString().split("\\.")[0];
        return f.formatCellValue(c).trim();
    }

    private boolean isRowEmpty(Row r) {
        if (r == null) return true;
        for (int c = r.getFirstCellNum(); c < r.getLastCellNum(); c++)
            if (r.getCell(c) != null && r.getCell(c).getCellType() != CellType.BLANK && !r.getCell(c).toString().trim().isEmpty()) return false;
        return true;
    }

}
