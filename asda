@JsonIgnoreProperties(ignoreUnknown = true)
@JsonFormat(shape = JsonFormat.Shape.ARRAY)
@JsonPropertyOrder({
        "rowIndex", "branch", "currency", "cgl", "txnType", "remarks",
        "productCode", "amount", "isSystemFormat", "sysSite", "sysDate",
        "sysYear", "sysPeriod", "formatErrors", "dbErrors", "balErrors"
})
public class ExcelRowData {

    @JsonProperty("0") // rowIndex
    public int rowIndex;

    @JsonProperty("1") // branch
    public String branch = "";

    @JsonProperty("2") // currency
    public String currency = "";

    @JsonProperty("3") // cgl
    public String cgl = "";

    @JsonProperty("4") // txnType
    public String txnType = "";

    @JsonProperty("5") // remarks
    public String remarks = "";

    @JsonProperty("6") // productCode
    public String productCode = "";

    @JsonProperty("7") // amount
    public BigDecimal amount;

    @JsonProperty("8") // isSystemFormat
    public boolean isSystemFormat = false;

    @JsonProperty("9") // sysSite
    public String sysSite = "";

    @JsonProperty("10") // sysDate
    public String sysDate = "";

    @JsonProperty("11") // sysYear
    public String sysYear = "";

    @JsonProperty("12") // sysPeriod
    public String sysPeriod = "";

    // Validation Lists (Indices 13, 14, 15)
    @JsonProperty("13")
    public final List<String> formatErrors = Collections.synchronizedList(new ArrayList<>());

    @JsonProperty("14")
    public final List<String> dbErrors = Collections.synchronizedList(new ArrayList<>());

    @JsonProperty("15")
    public final List<String> balErrors = Collections.synchronizedList(new ArrayList<>());

    public boolean hasErrors() {
        return !formatErrors.isEmpty() || !dbErrors.isEmpty() || !balErrors.isEmpty();
    }

    @JsonIgnore
    public String getAllErrors() {
        List<String> all = new ArrayList<>(formatErrors);
        all.addAll(dbErrors);
        all.addAll(balErrors);
        return String.join("; ", all);
    }
}


